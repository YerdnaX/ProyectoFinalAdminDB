            <a href="/billing/pagar" style="padding:.5rem .75rem;border-radius:6px;font-size:.875rem;color:var(--gris-oscuro);display:block;text-decoration:none;" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background=''">💳 Realizar pago</a>
            <a href="/billing/facturas" style="padding:.5rem .75rem;border-radius:6px;font-size:.875rem;color:var(--gris-oscuro);display:block;text-decoration:none;" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background=''">📋 Facturas (admin)</a>
