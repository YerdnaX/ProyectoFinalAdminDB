            <a href="/auth/login" style="padding:.5rem .75rem;border-radius:6px;font-size:.875rem;color:var(--gris-oscuro);display:block;text-decoration:none;" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background=''">🔑 Iniciar sesión</a>
            <a href="/auth/recuperar-acceso" style="padding:.5rem .75rem;border-radius:6px;font-size:.875rem;color:var(--gris-oscuro);display:block;text-decoration:none;" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background=''">🔓 Recuperar acceso</a>
