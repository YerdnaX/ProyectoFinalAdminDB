        <div style="font-size:2.5rem;margin-bottom:1rem;">🔐</div>
        <h2 style="color:#fff;margin-bottom:.5rem;">Acceso al sistema</h2>
        <p style="color:rgba(255,255,255,.6);margin:0;">Página de inicio de sesión institucional</p>
      </a>
      <div style="display:flex;flex-direction:column;gap:1rem;">
        <a href="/admin" style="display:flex;align-items:center;gap:1rem;background:var(--verde-principal);color:#fff;border-radius:var(--radio-borde);padding:1.25rem;text-decoration:none;">
