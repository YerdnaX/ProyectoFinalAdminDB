<div id="modal-detalle-factura-global" class="modal">
  <div class="modal-overlay" onclick="U.closeModal('modal-detalle-factura-global')"></div>
  <div class="modal-caja" style="max-width:640px;">
    <div class="modal-cabecera">
      <div class="modal-titulo">Detalle de factura</div>
      <button type="button" class="modal-cerrar" onclick="U.closeModal('modal-detalle-factura-global')">&times;</button>
    </div>
    <div class="modal-cuerpo" style="display:flex;flex-direction:column;gap:1rem;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem 1rem;">
        <div><div class="texto-muted" style="font-size:.8rem;">N. Factura</div><div id="det-fac-numero" style="font-family:monospace;font-weight:700;">-</div></div>
        <div><div class="texto-muted" style="font-size:.8rem;">Estado</div><div id="det-fac-estado">-</div></div>
        <div><div class="texto-muted" style="font-size:.8rem;">Estudiante</div><div id="det-fac-estudiante">-</div></div>
        <div><div class="texto-muted" style="font-size:.8rem;">Periodo</div><div id="det-fac-periodo">-</div></div>
        <div><div class="texto-muted" style="font-size:.8rem;">Total</div><div id="det-fac-total" style="font-weight:700;">-</div></div>
        <div><div class="texto-muted" style="font-size:.8rem;">Saldo</div><div id="det-fac-saldo" style="font-weight:700;">-</div></div>
      </div>

      <div class="tabla-contenedor">
        <table class="tabla">
          <thead><tr><th>Descripcion</th><th style="text-align:right;">Monto</th></tr></thead>
          <tbody id="det-fac-lineas"><tr><td colspan="2" style="text-align:center;color:var(--gris-suave);">Sin detalle disponible.</td></tr></tbody>
        </table>
      </div>
    </div>
    <div class="modal-pie" style="display:flex;justify-content:flex-end;gap:.5rem;">
      <button type="button" class="btn btn-secundario" onclick="U.closeModal('modal-detalle-factura-global')">Cerrar</button>
    </div>
  </div>
</div>
