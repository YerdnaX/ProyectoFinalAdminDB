    <a href="/academic/secciones" {{#eq activePage "secciones"}}class="activo"{{/eq}}><span class="icono">🗂️</span> Secciones</a>
    <a href="/academic/aulas" {{#eq activePage "aulas"}}class="activo"{{/eq}}><span class="icono">🏫</span> Aulas</a>
