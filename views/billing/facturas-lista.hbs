  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Facturación</div>
        <div class="navbar-breadcrumb"><span>Inicio</span><span class="separador"></span><span class="actual">Facturas</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="navbar-usuario"><div class="avatar">AM</div><div><div class="navbar-usuario-nombre">Ana Mora</div><div class="navbar-usuario-rol">Administradora TI</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Gestión de facturas</h1><p>Consulta y administra todas las facturas del sistema.</p></div>
        <div class="acciones-encabezado">
          <button class="btn btn-secundario">Exportar</button>
        </div>
      </div>

      <!-- Métricas -->
      <div class="grid-4 mb-4">
        <div class="carta-metrica"><div class="metrica-icono">🧾</div><div class="metrica-etiqueta">Total emitidas</div><div class="metrica-valor">3,842</div><div class="metrica-cambio positivo">I Semestre 2025</div></div>
        <div class="carta-metrica"><div class="metrica-icono">✅</div><div class="metrica-etiqueta">Pagadas</div><div class="metrica-valor">2,999</div><div class="metrica-cambio positivo">78.1%</div></div>
        <div class="carta-metrica amarillo"><div class="metrica-icono">⏳</div><div class="metrica-etiqueta">Pendientes</div><div class="metrica-valor">843</div><div class="metrica-cambio negativo">21.9%</div></div>
        <div class="carta-metrica rojo"><div class="metrica-icono">💰</div><div class="metrica-etiqueta">Saldo por cobrar</div><div class="metrica-valor">₡82M</div><div class="metrica-cambio negativo">Requiere gestión</div></div>
      </div>

      <div class="carta">
        <div class="carta-cabecera">
          <div class="barra-filtros" style="margin:0;flex:1;">
            <div class="barra-busqueda"><span class="icono-buscar">🔍</span><input type="text" placeholder="Buscar por N.° factura, carné o estudiante..."></div>
            <select class="filtro-select"><option>Todos los estados</option><option>Pagada</option><option>Pendiente</option><option>Vencida</option></select>
            <select class="filtro-select"><option>I Semestre 2025</option><option>II Semestre 2024</option></select>
          </div>
        </div>

        <div class="tabla-contenedor">
          <table class="tabla">
            <thead>
              <tr>
                <th>N.° Factura</th>
                <th>Estudiante</th>
                <th>Periodo</th>
                <th>Emisión</th>
                <th style="text-align:right;">Total</th>
                <th style="text-align:right;">Saldo</th>
                <th>Estado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><span style="font-family:monospace;font-weight:700;">F-2025-00812</span></td>
                <td><div class="nombre-principal">Laura Jiménez Rojas</div><div class="detalle-secundario">2024-0312</div></td>
                <td class="texto-muted">I Sem. 2025</td>
                <td class="texto-muted">22/01/2025</td>
                <td style="text-align:right;font-weight:600;">₡185,000</td>
                <td style="text-align:right;font-weight:600;color:var(--rojo-peligro);">₡185,000</td>
                <td><span class="badge badge-pendiente">Pendiente</span></td>
                <td><div class="acciones-fila"><button class="btn btn-secundario btn-sm">Ver</button><button class="btn btn-primario btn-sm">Registrar pago</button></div></td>
              </tr>
              <tr>
                <td><span style="font-family:monospace;font-weight:700;">F-2025-00811</span></td>
                <td><div class="nombre-principal">María Castillo Ureña</div><div class="detalle-secundario">2022-0784</div></td>
                <td class="texto-muted">I Sem. 2025</td>
                <td class="texto-muted">21/01/2025</td>
                <td style="text-align:right;font-weight:600;">₡168,000</td>
                <td style="text-align:right;font-weight:600;color:var(--cyan-exito);">₡0</td>
                <td><span class="badge badge-confirmado">Pagada</span></td>
                <td><div class="acciones-fila"><button class="btn btn-secundario btn-sm">Ver</button></div></td>
              </tr>
              <tr>
                <td><span style="font-family:monospace;font-weight:700;">F-2025-00809</span></td>
                <td><div class="nombre-principal">Roberto Solano Castro</div><div class="detalle-secundario">2023-1145</div></td>
                <td class="texto-muted">I Sem. 2025</td>
                <td class="texto-muted">20/01/2025</td>
                <td style="text-align:right;font-weight:600;">₡220,000</td>
                <td style="text-align:right;font-weight:600;color:var(--rojo-peligro);">₡420,000</td>
                <td><span class="badge badge-error">Vencida</span></td>
                <td><div class="acciones-fila"><button class="btn btn-secundario btn-sm">Ver</button><button class="btn btn-peligro btn-sm">Gestionar</button></div></td>
              </tr>
              <tr>
                <td><span style="font-family:monospace;font-weight:700;">F-2025-00805</span></td>
                <td><div class="nombre-principal">Pablo Gutiérrez Mora</div><div class="detalle-secundario">2021-0456</div></td>
                <td class="texto-muted">I Sem. 2025</td>
                <td class="texto-muted">18/01/2025</td>
                <td style="text-align:right;font-weight:600;">₡140,000</td>
                <td style="text-align:right;font-weight:600;color:var(--cyan-exito);">₡0</td>
                <td><span class="badge badge-confirmado">Pagada</span></td>
                <td><div class="acciones-fila"><button class="btn btn-secundario btn-sm">Ver</button></div></td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="paginacion">
          <span class="paginacion-info">Mostrando 1–4 de 3,842 facturas</span>
          <div class="paginacion-botones">
            <button class="btn-pagina" disabled>←</button>
            <button class="btn-pagina activa">1</button>
            <button class="btn-pagina">2</button>
            <button class="btn-pagina">3</button>
            <button class="btn-pagina">→</button>
          </div>
        </div>
