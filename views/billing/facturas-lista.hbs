<div class="app-wrapper">
  {{> sidebar-admin}}

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Facturacion</div>
        <div class="navbar-breadcrumb"><span>Inicio</span><span class="separador"></span><span class="actual">Facturas</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="navbar-usuario"><div class="avatar">AM</div><div><div class="navbar-usuario-nombre">Ana Mora</div><div class="navbar-usuario-rol">Administradora TI</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Gestion de facturas</h1><p>Consulta y administra todas las facturas del sistema.</p></div>
        <div class="acciones-encabezado">
          <a href="/api/reports/export/facturas" class="btn btn-secundario">Exportar</a>
        </div>
      </div>

      <div class="carta">
        <div class="carta-cabecera">
          <div class="barra-filtros" style="margin:0;flex:1;">
            <div class="barra-busqueda"><span class="icono-buscar">&#128269;</span><input id="input-buscar" type="text" placeholder="Buscar por N. factura, carne, estudiante o periodo..."></div>
            <select id="sel-estado" class="filtro-select">
              <option value="">Todos los estados</option>
              <option value="Pagada">Pagada</option>
              <option value="Pendiente">Pendiente</option>
              <option value="Parcial">Parcial</option>
              <option value="Anulada">Anulada</option>
            </select>
          </div>
        </div>

        <div class="tabla-contenedor">
          <table class="tabla">
            <thead>
              <tr>
                <th>N. Factura</th>
                <th>Estudiante</th>
                <th>Periodo</th>
                <th>Emision</th>
                <th style="text-align:right;">Total</th>
                <th style="text-align:right;">Saldo</th>
                <th>Estado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody id="tbody-facturas">
              <tr><td colspan="8" style="text-align:center;padding:2rem;color:var(--gris-suave);">Cargando...</td></tr>
            </tbody>
          </table>
        </div>

        <div id="paginacion-facturas" class="paginacion"></div>
      </div>
    </main>
  </div>
</div>

{{> modal-detalle-factura}}

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/billing-detalle-factura.js"></script>
<script src="/js/billing-facturas.js"></script>
