<div class="app-wrapper">
  {{> sidebar-admin}}

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Facturación</div>
        <div class="navbar-breadcrumb"><span>Inicio</span><span class="separador"></span><span class="actual">Facturas</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="navbar-usuario"><div class="avatar">AM</div><div><div class="navbar-usuario-nombre">Ana Mora</div><div class="navbar-usuario-rol">Administradora TI</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Gestión de facturas</h1><p>Consulta y administra todas las facturas del sistema.</p></div>
        <div class="acciones-encabezado">
          <button class="btn btn-secundario">Exportar</button>
        </div>
      </div>

      <!-- Métricas -->
      <div class="grid-4 mb-4">
        <div class="carta-metrica"><div class="metrica-icono">🧾</div><div class="metrica-etiqueta">Total emitidas</div><div class="metrica-valor">3,842</div><div class="metrica-cambio positivo">I Semestre 2025</div></div>
        <div class="carta-metrica"><div class="metrica-icono">✅</div><div class="metrica-etiqueta">Pagadas</div><div class="metrica-valor">2,999</div><div class="metrica-cambio positivo">78.1%</div></div>
        <div class="carta-metrica amarillo"><div class="metrica-icono">⏳</div><div class="metrica-etiqueta">Pendientes</div><div class="metrica-valor">843</div><div class="metrica-cambio negativo">21.9%</div></div>
        <div class="carta-metrica rojo"><div class="metrica-icono">💰</div><div class="metrica-etiqueta">Saldo por cobrar</div><div class="metrica-valor">₡82M</div><div class="metrica-cambio negativo">Requiere gestión</div></div>
      </div>

      <div class="carta">
        <div class="carta-cabecera">
          <div class="barra-filtros" style="margin:0;flex:1;">
            <div class="barra-busqueda"><span class="icono-buscar">🔍</span><input id="input-buscar" type="text" placeholder="Buscar por N.° factura, carné o estudiante..."></div>
            <select id="sel-estado" class="filtro-select"><option value="">Todos los estados</option><option>Pagada</option><option>Pendiente</option><option>Parcial</option><option>Anulada</option></select>
          </div>
        </div>

        <div class="tabla-contenedor">
          <table class="tabla">
            <thead>
              <tr>
                <th>N.° Factura</th>
                <th>Estudiante</th>
                <th>Periodo</th>
                <th>Emisión</th>
                <th style="text-align:right;">Total</th>
                <th style="text-align:right;">Saldo</th>
                <th>Estado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody id="tbody-facturas">
              <tr><td colspan="9" style="text-align:center;padding:2rem;color:var(--gris-suave);">Cargando…</td></tr>
                <td><div class="nombre-principal">Laura Jiménez Rojas</div><div class="detalle-secundario">2024-0312</div></td>
                <td class="texto-muted">I Sem. 2025</td>
            </tbody>
          </table>
        </div>
        <div id="paginacion-facturas" class="paginacion"></div>
      </div>
    </main>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/billing-facturas.js"></script>