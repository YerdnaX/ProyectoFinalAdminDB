<div class="app-wrapper">
  {{> sidebar-admin}}

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Registro de Pagos</div>
        <div class="navbar-breadcrumb"><span>Inicio</span><span class="separador"></span><span class="actual">Pagos</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="navbar-usuario"><div class="avatar">AM</div><div><div class="navbar-usuario-nombre">Ana Mora</div><div class="navbar-usuario-rol">Administradora TI</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Historial de pagos</h1><p>Consulta todos los pagos registrados en el sistema.</p></div>
        <div class="acciones-encabezado">
          <a href="/api/reports/export/pagos" class="btn btn-secundario">Exportar CSV</a>
          <button id="btn-pago-manual" class="btn btn-primario">+ Registrar pago manual</button>
        </div>
      </div>

      <div class="grid-3 mb-4">
        <div class="carta-metrica"><div class="metrica-icono">💵</div><div class="metrica-etiqueta">Recaudado hoy</div><div class="metrica-valor">₡8.2M</div><div class="metrica-cambio positivo">▲ 42 transacciones</div></div>
        <div class="carta-metrica"><div class="metrica-icono">📆</div><div class="metrica-etiqueta">Recaudado este mes</div><div class="metrica-valor">₡284M</div><div class="metrica-cambio positivo">▲ 73% de la meta</div></div>
        <div class="carta-metrica azul"><div class="metrica-icono">💳</div><div class="metrica-etiqueta">Pagos en línea</div><div class="metrica-valor">89%</div><div class="metrica-cambio positivo">▲ vs 71% año anterior</div></div>
      </div>

      <div class="carta">
        <div class="carta-cabecera">
          <div class="barra-filtros" style="margin:0;flex:1;">
            <div class="barra-busqueda"><span class="icono-buscar">🔍</span><input type="text" placeholder="Buscar por referencia, estudiante o factura..."></div>
            <select id="sel-metodo" class="filtro-select"><option value="">Todos los métodos</option><option>Tarjeta</option><option>Transferencia</option><option>SINPE</option><option>Efectivo</option></select>
            <select id="sel-estado" class="filtro-select"><option value="">Todos los estados</option><option>Aprobado</option><option>Pendiente</option><option>Rechazado</option></select>
          </div>
        </div>
        <div class="tabla-contenedor">
          <table class="tabla">
            <thead>
              <tr>
                <th>Fecha / hora</th>
                <th>Estudiante</th>
                <th>Factura</th>
                <th>Método</th>
                <th>Referencia</th>
                <th style="text-align:right;">Monto</th>
                <th>Estado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody id="tbody-pagos">
              <tr><td colspan="8" style="text-align:center;padding:2rem;color:var(--gris-suave);">Cargando…</td></tr>
            </tbody>
          </table>
        </div>
        <div id="paginacion-pagos" class="paginacion"></div>
      </div>
    </main>
  </div>
</div>
<!-- Modal registrar pago manual -->
<div id="modal-pago-manual" class="modal">
  <div class="modal-overlay" onclick="U.closeModal('modal-pago-manual')"></div>
  <div class="modal-caja" style="max-width:500px;">
    <div class="modal-cabecera">
      <div class="modal-titulo">Registrar pago manual</div>
      <button class="modal-cerrar" onclick="U.closeModal('modal-pago-manual')">✕</button>
    </div>
    <form id="form-pago-manual" class="modal-cuerpo" style="display:flex;flex-direction:column;gap:1rem;">
      <div class="campo" style="margin:0;">
        <label>N.° de factura <span class="requerido">*</span></label>
        <div style="display:flex;gap:.5rem;">
          <input id="pago-numero-factura" class="campo-input" placeholder="ej. FAC-0001" style="flex:1;">
          <button type="button" id="btn-buscar-factura" class="btn btn-secundario btn-sm">Buscar</button>
        </div>
      </div>
      <div id="pago-info-factura" style="display:none;background:var(--gris-fondo);border-radius:var(--radio-base);padding:.75rem 1rem;font-size:.875rem;">
        <div id="pago-factura-detalle"></div>
      </div>
      <input type="hidden" id="pago-id-factura">
      <div class="campo" style="margin:0;">
        <label>Monto a pagar (₡) <span class="requerido">*</span></label>
        <input id="pago-monto" class="campo-input" type="number" min="1" step="0.01" placeholder="0.00">
      </div>
      <div class="campo" style="margin:0;">
        <label>Método de pago <span class="requerido">*</span></label>
        <select id="pago-metodo" class="campo-input">
          <option value="">Seleccionar…</option>
          <option value="Efectivo">Efectivo</option>
          <option value="Transferencia">Transferencia</option>
          <option value="SINPE">SINPE</option>
          <option value="Tarjeta">Tarjeta</option>
          <option value="Cheque">Cheque</option>
        </select>
      </div>
      <div class="campo" style="margin:0;">
        <label>Referencia / comprobante</label>
        <input id="pago-referencia" class="campo-input" placeholder="Número de referencia opcional">
      </div>
      <div class="campo" style="margin:0;">
        <label>Observación</label>
        <textarea id="pago-observacion" class="campo-input" rows="2" placeholder="Notas adicionales"></textarea>
      </div>
      <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem;">
        <button type="button" class="btn btn-secundario" onclick="U.closeModal('modal-pago-manual')">Cancelar</button>
        <button type="submit" id="btn-pago-submit" class="btn btn-primario">Registrar pago</button>
      </div>
    </form>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/billing-pagos.js"></script>