<div class="app-wrapper">
  {{> sidebar-admin}}

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Registro de Pagos</div>
        <div class="navbar-breadcrumb"><span>Inicio</span><span class="separador"></span><span class="actual">Pagos</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="navbar-usuario"><div class="avatar">AM</div><div><div class="navbar-usuario-nombre">Ana Mora</div><div class="navbar-usuario-rol">Administradora TI</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Historial de pagos</h1><p>Consulta todos los pagos registrados en el sistema.</p></div>
        <div class="acciones-encabezado">
          <a href="/api/reports/export/pagos" class="btn btn-secundario">Exportar CSV</a>
        </div>
      </div>

      <div class="grid-3 mb-4">
        <div class="carta-metrica"><div class="metrica-icono">&#128181;</div><div class="metrica-etiqueta">Total recaudado</div><div id="total-recaudado" class="metrica-valor">-</div></div>
        <div class="carta-metrica"><div class="metrica-icono">&#128197;</div><div class="metrica-etiqueta">Pagos filtrados</div><div id="total-filtrados" class="metrica-valor">-</div></div>
        <div class="carta-metrica azul"><div class="metrica-icono">&#128179;</div><div class="metrica-etiqueta">Pagina actual</div><div id="pagina-actual" class="metrica-valor">1</div></div>
      </div>

      <div class="carta">
        <div class="carta-cabecera">
          <div class="barra-filtros" style="margin:0;flex:1;">
            <div class="barra-busqueda"><span class="icono-buscar">&#128269;</span><input id="input-buscar-pagos" type="text" placeholder="Buscar por referencia, estudiante, carne o factura..."></div>
            <select id="sel-metodo" class="filtro-select"><option value="">Todos los metodos</option><option>Tarjeta</option><option>Transferencia</option><option>SINPE</option><option>Efectivo</option></select>
            <select id="sel-estado" class="filtro-select"><option value="">Todos los estados</option><option>Aprobado</option><option>Pendiente</option><option>Rechazado</option><option>Reversado</option></select>
          </div>
        </div>
        <div class="tabla-contenedor">
          <table class="tabla">
            <thead>
              <tr>
                <th>Fecha</th>
                <th>Estudiante</th>
                <th>Factura</th>
                <th>Metodo</th>
                <th>Referencia</th>
                <th style="text-align:right;">Monto</th>
                <th>Estado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody id="tbody-pagos">
              <tr><td colspan="8" style="text-align:center;padding:2rem;color:var(--gris-suave);">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
        <div id="paginacion-pagos" class="paginacion"></div>
      </div>
    </main>
  </div>
</div>

{{> modal-detalle-factura}}

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/billing-detalle-factura.js"></script>
<script src="/js/billing-pagos.js"></script>
