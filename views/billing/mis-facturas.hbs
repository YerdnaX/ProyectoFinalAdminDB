    </nav>
    <div class="sidebar-footer"><a href="/auth/logout">🚪 Cerrar sesión</a></div>
  </aside>
  <div class="contenido-principal">
    <header class="navbar">
      <div><div class="navbar-titulo">Mis Facturas</div><div class="navbar-breadcrumb"><a href="/students">Inicio</a><span class="separador"></span><span class="actual">Mis facturas</span></div></div>
      <div class="navbar-acciones"><div class="navbar-usuario"><div class="avatar">LJ</div><div><div class="navbar-usuario-nombre">Laura Jiménez</div><div class="navbar-usuario-rol">Estudiante · 2024-0312</div></div></div></div>
    </header>
    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Mis facturas</h1><p>Historial completo de facturas de tu cuenta estudiantil.</p></div>
      </div>
      <div id="alerta-pendientes" class="alerta alerta-alerta mb-4" style="display:none;">
        <span class="alerta-icono">⚠️</span>
        <div id="alerta-pendientes-texto">Tienes facturas pendientes de pago. <a href="/billing/pagar">Pagar ahora →</a></div>
      </div>
      <div class="carta">
        <div class="tabla-contenedor">
          <table class="tabla">
            <thead><tr><th>N.° Factura</th><th>Periodo</th><th>Emisión</th><th style="text-align:right;">Total</th><th style="text-align:right;">Saldo</th><th>Estado</th><th>Acciones</th></tr></thead>
            <tbody id="tbody-mis-facturas">
              <tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--gris-suave);">Cargando…</td></tr>
            </tbody>
          </table>
        </div>
        <div id="paginacion-mis-facturas" class="paginacion"></div>
      </div>
    </main>
  </div>
</div>
<!-- Modal: Detalle de factura -->
<div id="modal-detalle-factura" class="modal-overlay" style="display:none;" onclick="if(event.target===this)U.closeModal('modal-detalle-factura')">
  <div class="modal-caja" style="max-width:520px;">
    <div class="modal-encabezado">
      <h2 class="modal-titulo">Detalle de factura</h2>
      <button class="modal-cerrar" onclick="U.closeModal('modal-detalle-factura')">✕</button>
    </div>
    <div class="modal-cuerpo">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem 1.5rem;margin-bottom:1rem;">
        <div><div class="texto-muted" style="font-size:.8rem;">N.° Factura</div><div style="font-family:monospace;font-weight:700;" id="modal-det-numero">—</div></div>
        <div><div class="texto-muted" style="font-size:.8rem;">Período</div><div id="modal-det-periodo">—</div></div>
        <div><div class="texto-muted" style="font-size:.8rem;">Fecha emisión</div><div id="modal-det-fecha">—</div></div>
        <div><div class="texto-muted" style="font-size:.8rem;">Estado</div><div id="modal-det-estado">—</div></div>
        <div><div class="texto-muted" style="font-size:.8rem;">Total</div><div style="font-weight:600;" id="modal-det-total">—</div></div>
        <div><div class="texto-muted" style="font-size:.8rem;">Saldo pendiente</div><div style="font-weight:600;" id="modal-det-saldo">—</div></div>
      </div>
      <table class="tabla" style="width:100%;">
        <thead><tr><th>Descripción</th><th style="text-align:right;">Monto</th></tr></thead>
        <tbody id="modal-det-lineas"></tbody>
      </table>
    </div>
    <div class="modal-pie">
      <button class="btn btn-secundario" onclick="U.closeModal('modal-detalle-factura')">Cerrar</button>
    </div>
  </div>
</div>
<script>window._idEstudiante = {{id_estudiante}};</script>
