<div class="app-wrapper">
  <aside class="sidebar">
    <div class="sidebar-logo"><div class="sidebar-logo-icono">🎓</div><div><div class="sidebar-logo-texto">UniMatrícula</div><div class="sidebar-logo-subtexto">Portal Estudiantil</div></div></div>
    <nav class="sidebar-nav">
      <div class="sidebar-seccion">General</div>
      <a href="/students"><span class="icono">🏠</span> Mi portal</a>
      <div class="sidebar-seccion">Matrícula</div>
      <a href="/enrollment/buscar"><span class="icono">🔍</span> Buscar cursos</a>
      <a href="/enrollment/mi-matricula"><span class="icono">✏️</span> Mi matrícula</a>
      <div class="sidebar-seccion">Mi información</div>
      <a href="/students/mi-perfil"><span class="icono">👤</span> Mi perfil</a>
      <a href="/students/historial"><span class="icono">📊</span> Historial académico</a>
      <div class="sidebar-seccion">Finanzas</div>
      <a href="/billing/estado-cuenta" class="activo"><span class="icono">📄</span> Estado de cuenta</a>
      <a href="/billing/mis-facturas"><span class="icono">🧾</span> Mis facturas</a>
      <a href="/billing/pagar"><span class="icono">💳</span> Realizar pago</a>
      <div class="sidebar-seccion">Comunicaciones</div>
      <a href="/notifications"><span class="icono">🔔</span> Notificaciones</a>
    </nav>
    <div class="sidebar-footer"><a href="/auth/logout">🚪 Cerrar sesión</a></div>
  </aside>

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Estado de Cuenta</div>
        <div class="navbar-breadcrumb"><a href="/students">Inicio</a><span class="separador"></span><span class="actual">Estado de cuenta</span></div>
      </div>
      <div class="navbar-acciones">
        <button class="btn btn-secundario btn-sm">🖨️ Imprimir</button>
        <div class="navbar-usuario"><div class="avatar">LJ</div><div><div class="navbar-usuario-nombre">Laura Jiménez</div><div class="navbar-usuario-rol">Estudiante · 2024-0312</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Estado de cuenta</h1><p>Consulta el resumen financiero de tu cuenta estudiantil.</p></div>
        <div class="acciones-encabezado">
          <select class="filtro-select"><option>I Semestre 2025</option><option>II Semestre 2024</option><option>I Semestre 2024</option></select>
        </div>
      </div>

      <!-- Resumen financiero -->
      <div class="grid-3 mb-4">
        <div style="background:var(--rojo-peligro-bg);border:1px solid #FECACA;border-radius:var(--radio-grande);padding:1.5rem;text-align:center;">
          <div style="font-size:.875rem;font-weight:600;color:var(--rojo-peligro);margin-bottom:.5rem;">💰 Saldo pendiente</div>
          <div id="est-saldo" style="font-size:2rem;font-weight:700;color:var(--rojo-peligro);">—</div>
        </div>
        <div style="background:var(--verde-bg);border:1px solid var(--verde-claro);border-radius:var(--radio-grande);padding:1.5rem;text-align:center;">
          <div style="font-size:.875rem;font-weight:600;color:var(--verde-principal);margin-bottom:.5rem;">👤 Estudiante</div>
          <div id="est-nombre" style="font-size:1.25rem;font-weight:700;color:var(--verde-principal);">—</div>
          <div id="est-carne" class="texto-pequeno" style="margin-top:.375rem;"></div>
        </div>
        <div style="background:var(--gris-fondo);border-radius:var(--radio-grande);padding:1.5rem;text-align:center;">
          <div style="font-size:.875rem;font-weight:600;margin-bottom:.5rem;">🔔 Estado</div>
          <a href="/billing/pagar" class="btn btn-primario btn-sm">Ir a pagar</a>
        </div>
      </div>

      <div id="alerta-bloqueo" class="alerta alerta-peligro mb-4" style="display:none;">
        <span class="alerta-icono">🚨</span>
        <div><span class="alerta-titulo">Cuenta bloqueada financieramente.</span> <a href="/billing/pagar" style="color:var(--rojo-peligro);font-weight:700;">Pagar ahora →</a></div>
      </div>

      <!-- Historial de movimientos -->
      <div class="carta">
        <div class="carta-cabecera">
          <div><div class="carta-titulo">Movimientos del periodo</div><div class="carta-subtitulo">I Semestre 2025</div></div>
          <button class="btn btn-secundario btn-sm">Exportar PDF</button>
        </div>
        <div class="tabla-contenedor">
          <table class="tabla">
            <thead>
              <tr>
                <th>Fecha</th>
                <th>Periodo</th>
                <th style="text-align:right;">Total facturado</th>
                <th style="text-align:right;">Pagado</th>
                <th style="text-align:right;">Saldo pendiente</th>
                <th>Estado</th>
              </tr>
            </thead>
            <tbody id="tbody-estados">
              <tr><td colspan="6" style="text-align:center;padding:2rem;color:var(--gris-suave);">Cargando…</td></tr>
            </tbody>
          </table>
        </div>
        <div class="carta-pie">
          <div style="display:flex;justify-content:flex-end;gap:2rem;font-size:.9rem;">
            <div class="flex-entre" style="gap:1rem;"><span class="texto-gris">Total facturado:</span><span id="est-total-cargos" style="color:var(--rojo-peligro);font-weight:700;">—</span></div>
            <div class="flex-entre" style="gap:1rem;"><span class="texto-gris">Total pagado:</span><span id="est-total-abonos" style="color:var(--cyan-exito);font-weight:700;">—</span></div>
            <div class="flex-entre" style="gap:1rem;"><span class="texto-gris">Saldo actual:</span><span id="est-saldo-pie" style="font-weight:700;font-size:1rem;">—</span></div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
<script>window._idEstudiante = {{id_estudiante}};</script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/billing-estado.js"></script>
