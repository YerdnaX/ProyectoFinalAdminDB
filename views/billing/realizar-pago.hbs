<div class="app-wrapper">
  <aside class="sidebar">
    <div class="sidebar-logo"><div class="sidebar-logo-icono">🎓</div><div><div class="sidebar-logo-texto">UniMatrícula</div><div class="sidebar-logo-subtexto">Portal Estudiantil</div></div></div>
    <nav class="sidebar-nav">
      <div class="sidebar-seccion">General</div>
      <a href="/students"><span class="icono">🏠</span> Mi portal</a>
      <div class="sidebar-seccion">Matrícula</div>
      <a href="/enrollment/buscar"><span class="icono">🔍</span> Buscar cursos</a>
      <a href="/enrollment/mi-matricula"><span class="icono">✏️</span> Mi matrícula</a>
      <div class="sidebar-seccion">Mi información</div>
      <a href="/students/mi-perfil"><span class="icono">👤</span> Mi perfil</a>
      <a href="/students/historial"><span class="icono">📊</span> Historial académico</a>
      <div class="sidebar-seccion">Finanzas</div>
      <a href="/billing/estado-cuenta"><span class="icono">📄</span> Estado de cuenta</a>
      <a href="/billing/mis-facturas"><span class="icono">🧾</span> Mis facturas</a>
      <a href="/billing/pagar" class="activo"><span class="icono">💳</span> Realizar pago</a>
      <div class="sidebar-seccion">Comunicaciones</div>
      <a href="/notifications"><span class="icono">🔔</span> Notificaciones</a>
    </nav>
    <div class="sidebar-footer"><a href="/auth/logout">🚪 Cerrar sesión</a></div>
  </aside>

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Realizar Pago</div>
        <div class="navbar-breadcrumb"><a href="/students">Inicio</a><span class="separador"></span><span class="actual">Realizar pago</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="navbar-usuario"><div class="avatar">LJ</div><div><div class="navbar-usuario-nombre">Laura Jiménez</div><div class="navbar-usuario-rol">Estudiante · 2024-0312</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Realizar pago</h1><p>Selecciona una factura pendiente y completa el formulario.</p></div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 380px;gap:1.5rem;">
        <!-- Facturas pendientes -->
        <div>
          <div class="carta mb-4">
            <div class="carta-cabecera"><div class="carta-titulo">Facturas pendientes</div></div>
            <div class="tabla-contenedor">
              <table class="tabla">
                <thead><tr><th>N.° Factura</th><th>Periodo</th><th>Total</th><th>Saldo</th><th>Estado</th></tr></thead>
                <tbody id="tbody-facturas-pend">
                  <tr><td colspan="5" style="text-align:center;padding:2rem;color:var(--gris-suave);">Cargando…</td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <div id="comprobante-resultado" style="display:none;"></div>
        </div>

        <!-- Formulario de pago -->
        <div>
          <div class="carta" style="position:sticky;top:80px;">
            <div class="carta-cabecera"><div class="carta-titulo">Procesar pago</div></div>
            <form id="form-pagar" class="carta-cuerpo" style="display:flex;flex-direction:column;gap:1rem;">
              <div class="campo" style="margin:0;">
                <label>Factura <span class="requerido">*</span></label>
                <select id="sel-factura" name="id_factura" class="campo-input" required>
                  <option value="">Cargando…</option>
                </select>
              </div>
              <div class="campo" style="margin:0;">
                <label>Monto a pagar <span class="requerido">*</span></label>
                <input id="inp-monto" name="monto" class="campo-input" type="number" step="0.01" min="1" required placeholder="0.00">
              </div>
              <div class="campo" style="margin:0;">
                <label>Método de pago <span class="requerido">*</span></label>
                <select id="sel-metodo" name="metodo_pago" class="campo-input" required>
                  <option value="">Seleccionar…</option>
                  <option value="Tarjeta">💳 Tarjeta</option>
                  <option value="Transferencia">🏦 Transferencia</option>
                  <option value="SINPE">📱 SINPE</option>
                  <option value="Efectivo">🏢 Efectivo / Caja</option>
                </select>
              </div>
              <div class="alerta alerta-info" style="font-size:.8rem;">
                <span>🔒</span><span>Los pagos son registrados y procesados de forma segura.</span>
              </div>
              <button type="submit" class="btn btn-primario w-full btn-lg">🔒 Confirmar pago</button>
              <a href="/billing/estado-cuenta" class="btn btn-secundario w-full" style="display:flex;align-items:center;justify-content:center;">← Ver estado de cuenta</a>
            </form>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
<script>window._idEstudiante = {{id_estudiante}};</script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/billing-pagar.js"></script>
