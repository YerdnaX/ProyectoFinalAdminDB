{{#if idEstudiante}}<meta name="id-estudiante" content="{{idEstudiante}}">{{/if}}
<div class="app-wrapper">
  <aside class="sidebar">

    {{#if esEstudiante}}
    <!-- Sidebar Estudiante -->
    <div class="sidebar-logo"><div class="sidebar-logo-icono">🎓</div><div><div class="sidebar-logo-texto">UniMatrícula</div><div class="sidebar-logo-subtexto">Portal Estudiantil</div></div></div>
    <nav class="sidebar-nav">
      <div class="sidebar-seccion">General</div>
      <a href="/students"><span class="icono">🏠</span> Mi portal</a>
      <div class="sidebar-seccion">Matrícula</div>
      <a href="/enrollment/buscar"><span class="icono">🔍</span> Buscar cursos</a>
      <a href="/enrollment/mi-matricula"><span class="icono">✏️</span> Mi matrícula</a>
      <div class="sidebar-seccion">Mi información</div>
      <a href="/students/mi-perfil"><span class="icono">👤</span> Mi perfil</a>
      <a href="/students/historial"><span class="icono">📊</span> Historial académico</a>
      <div class="sidebar-seccion">Finanzas</div>
      <a href="/billing/estado-cuenta"><span class="icono">📄</span> Estado de cuenta</a>
      <a href="/billing/mis-facturas"><span class="icono">🧾</span> Mis facturas</a>
      <a href="/billing/pagar"><span class="icono">💳</span> Realizar pago</a>
      <div class="sidebar-seccion">Comunicaciones</div>
      <a href="/notifications" class="activo"><span class="icono">🔔</span> Notificaciones</a>
    </nav>

    {{else}}
    {{> sidebar-admin activePage="notificaciones"}}
    {{/if}}

    <div class="sidebar-footer"><a href="/auth/logout">🚪 Cerrar sesión</a></div>
  </aside>

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Notificaciones</div>
        <div class="navbar-breadcrumb">
          {{#if esEstudiante}}
          <a href="/students">Inicio</a>
          {{else}}
          <a href="/admin">Inicio</a>
          {{/if}}
          <span class="separador"></span><span class="actual">Notificaciones</span>
        </div>
      </div>
      <div class="navbar-acciones">
        <div class="icono-notif">🔔<span class="badge-notif"></span></div>
        <div class="navbar-usuario"><div class="avatar"></div><div><div class="navbar-usuario-nombre"></div><div class="navbar-usuario-rol"></div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div>
          <h1>{{#if esEstudiante}}Mis notificaciones{{else}}Notificaciones del sistema{{/if}}</h1>
          <p>Mensajes del sistema, alertas y comunicados institucionales.</p>
        </div>
      </div>

      <div class="barra-filtros mb-4">
        <select id="sel-tipo" class="filtro-select">
          <option value="">Todos los tipos</option>
          <option value="Matricula">Matrícula</option>
          <option value="Pago">Pago</option>
          <option value="Cobro">Cobro</option>
          <option value="Academico">Académico</option>
          <option value="Sistema">Sistema</option>
        </select>
        <select id="sel-estado-notif" class="filtro-select">
          <option value="">Todos los estados</option>
          <option value="Enviada">Enviada</option>
          <option value="Pendiente">Pendiente</option>
          <option value="Error">Error</option>
        </select>
      </div>

      <div class="carta">
        <div class="tabla-contenedor">
          <table class="tabla">
            <thead>
              <tr>
                <th>Fecha</th>
                <th>Hora</th>
                {{#unless esEstudiante}}<th>Estudiante</th>{{/unless}}
                <th>Tipo</th>
                <th>Asunto / Mensaje</th>
                <th>Medio</th>
                <th>Estado</th>
              </tr>
            </thead>
            <tbody id="tbody-notif">
              <tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--gris-suave);">Cargando…</td></tr>
            </tbody>
          </table>
        </div>
        <div id="paginacion-notif" class="paginacion"></div>
      </div>
    </main>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/notifications.js"></script>
