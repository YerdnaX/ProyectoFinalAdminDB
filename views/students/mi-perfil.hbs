                <div><h3 id="perfil-nombre-completo" style="margin-bottom:.25rem;">Cargando…</h3><div id="perfil-email" class="texto-muted">—</div></div>
              </div>
              <div class="campo-fila">
                <div class="campo"><label>Nombre</label><input id="perfil-nombre" class="campo-input" type="text" readonly style="background:var(--gris-fondo)"></div>
                <div class="campo"><label>Apellido</label><input id="perfil-apellido" class="campo-input" type="text" readonly style="background:var(--gris-fondo)"></div>
              </div>
              <div class="campo"><label>Correo institucional</label><input id="perfil-correo" class="campo-input" type="email" readonly style="background:var(--gris-fondo)"></div>
              <div class="alerta alerta-info" style="font-size:.875rem;">
                <span>ℹ️</span><span>Para modificar tu nombre o correo, contacta a Registro Académico.</span>
              </div>
            </div>
          </div>
          <div class="carta">
            <div class="carta-cabecera"><div class="carta-titulo">Datos académicos</div></div>
            <div class="carta-cuerpo">
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;font-size:.9rem;">
                <div><div class="texto-gris mb-1">Carné</div><div id="perfil-carne" style="font-family:monospace;font-weight:700;">—</div></div>
                <div><div class="texto-gris mb-1">Estado académico</div><div id="perfil-estado-acad">—</div></div>
                <div><div class="texto-gris mb-1">Programa</div><div id="perfil-programa" class="semibold">—</div></div>
                <div><div class="texto-gris mb-1">Plan de estudio</div><div id="perfil-plan" class="semibold">—</div></div>
                <div><div class="texto-gris mb-1">Fecha de ingreso</div><div id="perfil-ingreso" class="semibold">—</div></div>
                <div><div class="texto-gris mb-1">Identificador SSO</div><div id="perfil-sso" style="font-family:monospace;">—</div></div>
              </div>
            </div>
          </div>
        </div>
