<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Perfil Estudiante — Sistema de Matrícula</title>
<link rel="stylesheet" href="../../css/styles.css">
</head>
<body>
<div class="app-wrapper">
  <aside class="sidebar">
    <div class="sidebar-logo"><div class="sidebar-logo-icono">🎓</div><div><div class="sidebar-logo-texto">UniMatrícula</div><div class="sidebar-logo-subtexto">Panel Administrativo</div></div></div>
    <nav class="sidebar-nav">
      <div class="sidebar-seccion">General</div>
      <a href="../admin/dashboard-admin.html"><span class="icono">📊</span> Dashboard</a>
      <div class="sidebar-seccion">Usuarios</div>
      <a href="../admin/usuarios-lista.html"><span class="icono">👥</span> Usuarios</a>
      <a href="../admin/roles-permisos.html"><span class="icono">🔐</span> Roles y permisos</a>
      <div class="sidebar-seccion">Académico</div>
      <a href="../academic/programas-lista.html"><span class="icono">🏛️</span> Programas académicos</a>
      <a href="../academic/planes-lista.html"><span class="icono">📋</span> Planes de estudio</a>
      <a href="../academic/cursos-lista.html"><span class="icono">📚</span> Cursos</a>
      <a href="../academic/periodos-lista.html"><span class="icono">📅</span> Periodos académicos</a>
      <div class="sidebar-seccion">Oferta</div>
      <a href="../academic/secciones-lista.html"><span class="icono">🗂️</span> Secciones</a>
      <a href="../academic/aulas-lista.html"><span class="icono">🏫</span> Aulas</a>
      <div class="sidebar-seccion">Estudiantes</div>
      <a href="estudiantes-lista.html" class="activo"><span class="icono">🎓</span> Estudiantes</a>
      <a href="../enrollment/matriculas-lista.html"><span class="icono">✏️</span> Matrículas</a>
      <div class="sidebar-seccion">Finanzas</div>
      <a href="../billing/facturas-lista.html"><span class="icono">🧾</span> Facturas</a>
      <a href="../billing/pagos-lista.html"><span class="icono">💳</span> Pagos</a>
      <div class="sidebar-seccion">Sistema</div>
      <a href="../notifications/notificaciones-lista.html"><span class="icono">🔔</span> Notificaciones</a>
      <a href="../reports/reportes.html"><span class="icono">📈</span> Reportes</a>
      <a href="../audit/bitacora.html"><span class="icono">🔍</span> Bitácora</a>
    </nav>
    <div class="sidebar-footer"><a href="../auth/login.html">🚪 Cerrar sesión</a></div>
  </aside>

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Perfil de Estudiante</div>
        <div class="navbar-breadcrumb"><span>Inicio</span><span class="separador"></span><a href="estudiantes-lista.html">Estudiantes</a><span class="separador"></span><span class="actual">Laura Jiménez Rojas</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="navbar-usuario"><div class="avatar">AM</div><div><div class="navbar-usuario-nombre">Ana Mora</div><div class="navbar-usuario-rol">Administradora TI</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <!-- Header del perfil -->
      <div class="carta mb-4">
        <div class="carta-cuerpo">
          <div style="display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;">
            <div class="avatar" style="width:72px;height:72px;font-size:1.75rem;flex-shrink:0;">LJ</div>
            <div style="flex:1;min-width:240px;">
              <div style="display:flex;align-items:center;gap:.875rem;flex-wrap:wrap;margin-bottom:.375rem;">
                <h2 style="margin:0;">Laura Jiménez Rojas</h2>
                <span class="badge badge-activo">Regular</span>
              </div>
              <div style="display:flex;gap:1.5rem;flex-wrap:wrap;font-size:.875rem;color:var(--gris-suave);">
                <span>🪪 Carné: <strong style="color:var(--gris-oscuro);">2024-0312</strong></span>
                <span>📧 laura.jimenez@uni.ac.cr</span>
                <span>📅 Ingreso: Febrero 2024</span>
                <span>🏛️ Ing. en Sistemas</span>
              </div>
            </div>
            <div style="display:flex;gap:.75rem;">
              <button class="btn btn-secundario">Editar perfil</button>
              <button class="btn btn-fantasma">Bloquear</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Métricas rápidas -->
      <div class="grid-4 mb-4">
        <div style="background:var(--fondo-carta);border:1px solid var(--gris-linea);border-radius:var(--radio-borde);padding:1.25rem;text-align:center;">
          <div style="font-size:1.75rem;font-weight:700;color:var(--verde-principal);">48</div>
          <div class="texto-pequeno">Créditos aprobados</div>
        </div>
        <div style="background:var(--fondo-carta);border:1px solid var(--gris-linea);border-radius:var(--radio-borde);padding:1.25rem;text-align:center;">
          <div style="font-size:1.75rem;font-weight:700;color:var(--gris-oscuro);">12</div>
          <div class="texto-pequeno">Créditos actuales</div>
        </div>
        <div style="background:var(--fondo-carta);border:1px solid var(--gris-linea);border-radius:var(--radio-borde);padding:1.25rem;text-align:center;">
          <div style="font-size:1.75rem;font-weight:700;color:var(--azul-info);">82.5%</div>
          <div class="texto-pequeno">Avance del plan</div>
        </div>
        <div style="background:var(--fondo-carta);border:1px solid var(--gris-linea);border-radius:var(--radio-borde);padding:1.25rem;text-align:center;">
          <div style="font-size:1.75rem;font-weight:700;color:var(--cyan-exito);">₡0</div>
          <div class="texto-pequeno">Saldo pendiente</div>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 340px;gap:1.5rem;">
        <div>
          <!-- Tabs de historial -->
          <div class="carta">
            <div class="carta-cuerpo" style="padding-bottom:0;">
              <div class="tabs">
                <button class="tab-boton activo">Matrícula actual</button>
                <button class="tab-boton">Historial académico</button>
                <button class="tab-boton">Pagos y facturación</button>
                <button class="tab-boton">Notificaciones</button>
              </div>
            </div>
            <div class="carta-cuerpo">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;">
                <div><h4 style="margin-bottom:.125rem;">I Semestre 2025</h4><span class="texto-muted">Matrícula confirmada — 4 cursos</span></div>
                <a href="../enrollment/comprobante.html" class="btn btn-secundario btn-sm">Ver comprobante</a>
              </div>
              <div class="tabla-contenedor">
                <table class="tabla">
                  <thead><tr><th>Código</th><th>Curso</th><th>Sección</th><th>Créditos</th><th>Horario</th><th>Estado</th></tr></thead>
                  <tbody>
                    <tr>
                      <td><span style="font-family:monospace;font-size:.875rem;color:var(--verde-principal);">IS-2201</span></td>
                      <td>Estructuras de Datos</td>
                      <td>IS-2201-01</td>
                      <td>4</td>
                      <td class="texto-muted">L-Mi 7:00–9:00</td>
                      <td><span class="badge badge-confirmado">Matriculado</span></td>
                    </tr>
                    <tr>
                      <td><span style="font-family:monospace;font-size:.875rem;color:var(--verde-principal);">IS-2202</span></td>
                      <td>Base de Datos I</td>
                      <td>IS-2202-01</td>
                      <td>3</td>
                      <td class="texto-muted">Ma-Ju 9:00–10:30</td>
                      <td><span class="badge badge-confirmado">Matriculado</span></td>
                    </tr>
                    <tr>
                      <td><span style="font-family:monospace;font-size:.875rem;color:var(--verde-principal);">MAT-1501</span></td>
                      <td>Cálculo I</td>
                      <td>MAT-1501-02</td>
                      <td>4</td>
                      <td class="texto-muted">L-Mi-Vi 10:00–11:00</td>
                      <td><span class="badge badge-confirmado">Matriculado</span></td>
                    </tr>
                    <tr>
                      <td><span style="font-family:monospace;font-size:.875rem;color:var(--verde-principal);">ING-1001</span></td>
                      <td>Inglés Técnico I</td>
                      <td>ING-1001-05</td>
                      <td>1</td>
                      <td class="texto-muted">Vi 13:00–15:00</td>
                      <td><span class="badge badge-confirmado">Matriculado</span></td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Panel lateral del estudiante -->
        <div>
          <div class="carta mb-3">
            <div class="carta-cabecera"><div class="carta-titulo">Estado del estudiante</div></div>
            <div class="carta-cuerpo">
              <div style="display:flex;flex-direction:column;gap:.875rem;font-size:.9rem;">
                <div class="flex-entre"><span class="texto-gris">Estado académico</span><span class="badge badge-activo">Regular</span></div>
                <div class="flex-entre"><span class="texto-gris">Bloqueo financiero</span><span class="badge badge-activo">Sin bloqueo</span></div>
                <div class="flex-entre"><span class="texto-gris">Bloqueo académico</span><span class="badge badge-activo">Sin bloqueo</span></div>
                <div class="flex-entre"><span class="texto-gris">Saldo pendiente</span><span style="font-weight:700;color:var(--cyan-exito);">₡0.00</span></div>
              </div>
            </div>
          </div>
          <div class="carta mb-3">
            <div class="carta-cabecera"><div class="carta-titulo">Avance del plan</div></div>
            <div class="carta-cuerpo">
              <div style="margin-bottom:1rem;">
                <div style="display:flex;justify-content:space-between;font-size:.875rem;margin-bottom:.5rem;"><span>Créditos aprobados</span><span style="font-weight:700;">48 / 160</span></div>
                <div class="progreso-contenedor"><div class="progreso-barra" style="width:30%;"></div></div>
                <div class="texto-pequeno mt-1">Plan de estudio: IS-2020</div>
              </div>
              <div style="font-size:.8125rem;display:flex;flex-direction:column;gap:.5rem;">
                <div class="flex-entre"><span class="texto-gris">Ciclo actual:</span><span class="semibold">II ciclo</span></div>
                <div class="flex-entre"><span class="texto-gris">Cursos aprobados:</span><span class="semibold">14 de 45</span></div>
                <div class="flex-entre"><span class="texto-gris">Cursos pendientes:</span><span class="semibold">31</span></div>
              </div>
            </div>
          </div>
          <div class="carta">
            <div class="carta-cabecera"><div class="carta-titulo">Acciones rápidas</div></div>
            <div class="carta-cuerpo" style="display:flex;flex-direction:column;gap:.625rem;">
              <a href="../billing/estado-cuenta.html" class="btn btn-secundario w-full" style="justify-content:flex-start;gap:.75rem;">📄 Ver estado de cuenta</a>
              <a href="../enrollment/comprobante.html" class="btn btn-secundario w-full" style="justify-content:flex-start;gap:.75rem;">🖨️ Comprobante de matrícula</a>
              <button class="btn btn-peligro w-full" style="justify-content:flex-start;gap:.75rem;">🚫 Activar bloqueo</button>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
</body>
</html>
