<div class="app-wrapper">
  {{> sidebar-admin}}

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Gestion de Estudiantes</div>
        <div class="navbar-breadcrumb"><span>Inicio</span><span class="separador"></span><span class="actual">Estudiantes</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="navbar-usuario"><div class="avatar">AM</div><div><div class="navbar-usuario-nombre">Ana Mora</div><div class="navbar-usuario-rol">Administradora TI</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Estudiantes</h1><p>Consulta y gestiona el padron completo de estudiantes.</p></div>
        <div class="acciones-encabezado">
          <a class="btn btn-secundario" href="/api/reports/export/estudiantes/pdf">Exportar PDF</a>
        </div>
      </div>

      <div class="carta">
        <div class="carta-cabecera">
          <div class="barra-filtros" style="margin:0;flex:1;">
            <div class="barra-busqueda"><span class="icono-buscar">&#128269;</span><input id="input-buscar" type="text" placeholder="Buscar por nombre, carne o correo..."></div>
            <select id="sel-programa" class="filtro-select"><option value="">Todos los programas</option></select>
            <select id="sel-estado" class="filtro-select">
              <option value="">Todos los estados</option>
              <option value="Activo">Activo</option>
              <option value="Inactivo">Inactivo</option>
              <option value="Graduado">Graduado</option>
              <option value="Suspendido">Suspendido</option>
            </select>
          </div>
        </div>

        <div class="tabla-contenedor">
          <table class="tabla">
            <thead>
              <tr>
                <th>Estudiante</th>
                <th>Carne</th>
                <th>Programa</th>
                <th>Ingreso</th>
                <th>Estado academico</th>
                <th>Saldo pendiente</th>
                <th>Bloqueos</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody id="tbody-estudiantes">
              <tr><td colspan="8" style="text-align:center;padding:2rem;color:var(--gris-suave);">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
        <div id="paginacion-estudiantes" class="paginacion"></div>
      </div>
    </main>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/students-lista.js"></script>
