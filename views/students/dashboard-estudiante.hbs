<div class="app-wrapper">
  <aside class="sidebar">
    <div class="sidebar-logo"><div class="sidebar-logo-icono">🎓</div><div><div class="sidebar-logo-texto">UniMatrícula</div><div class="sidebar-logo-subtexto">Portal Estudiantil</div></div></div>
    <nav class="sidebar-nav">
      <div class="sidebar-seccion">General</div>
      <a href="/students" class="activo"><span class="icono">🏠</span> Mi portal</a>
      <div class="sidebar-seccion">Matrícula</div>
      <a href="/enrollment/buscar"><span class="icono">🔍</span> Buscar cursos</a>
      <a href="/enrollment/mi-matricula"><span class="icono">✏️</span> Mi matrícula</a>
      <a href="/enrollment/comprobante"><span class="icono">🖨️</span> Comprobante</a>
      <div class="sidebar-seccion">Mi información</div>
      <a href="/students/mi-perfil"><span class="icono">👤</span> Mi perfil</a>
      <a href="/students/historial"><span class="icono">📊</span> Historial académico</a>
      <div class="sidebar-seccion">Finanzas</div>
      <a href="/billing/estado-cuenta"><span class="icono">📄</span> Estado de cuenta</a>
      <a href="/billing/mis-facturas"><span class="icono">🧾</span> Mis facturas</a>
      <a href="/billing/pagar"><span class="icono">💳</span> Realizar pago</a>
      <div class="sidebar-seccion">Comunicaciones</div>
      <a href="/notifications"><span class="icono">🔔</span> Notificaciones</a>
    </nav>
    <div class="sidebar-footer"><a href="/auth/logout">🚪 Cerrar sesión</a></div>
  </aside>

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Mi Portal Estudiantil</div>
        <div class="navbar-breadcrumb"><span class="actual">Inicio</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="icono-notif">🔔<span class="badge-notif">2</span></div>
        <div class="navbar-usuario"><div class="avatar">LJ</div><div><div class="navbar-usuario-nombre">Laura Jiménez</div><div class="navbar-usuario-rol">Estudiante · 2024-0312</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <!-- Saludo -->
      <div style="background:linear-gradient(135deg,var(--verde-principal),var(--verde-hover));border-radius:var(--radio-grande);padding:2rem;color:#fff;margin-bottom:1.75rem;">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
          <div>
            <h2 id="saludo-nombre" style="color:#fff;margin-bottom:.375rem;">¡Bienvenido! 👋</h2>
            <p id="saludo-matricula" style="color:rgba(255,255,255,.85);margin:0;">Cargando información…</p>
          </div>
          <a href="/enrollment/buscar" class="btn" style="background:rgba(255,255,255,.2);color:#fff;border:1px solid rgba(255,255,255,.4);">Buscar más cursos →</a>
        </div>
      </div>

      <!-- Alertas -->
      <div id="alerta-pago" class="alerta alerta-alerta mb-4" style="display:none;">
        <span class="alerta-icono">⚠️</span>
        <div id="alerta-pago-texto"><span class="alerta-titulo">Pago pendiente.</span> <a href="/billing/pagar">Pagar ahora →</a></div>
      </div>

      <!-- Métricas estudiante -->
      <div class="grid-metricas mb-4">
        <div class="carta-metrica"><div class="metrica-icono">📚</div><div class="metrica-etiqueta">Cursos matriculados</div><div id="met-cursos" class="metrica-valor">—</div><div id="met-periodo" class="metrica-cambio positivo">—</div></div>
        <div class="carta-metrica"><div class="metrica-icono">⭐</div><div class="metrica-etiqueta">Créditos actuales</div><div id="met-creditos" class="metrica-valor">—</div><div id="met-limite-cred" class="metrica-cambio positivo">—</div></div>
        <div class="carta-metrica azul"><div class="metrica-icono">🎯</div><div class="metrica-etiqueta">Avance del plan</div><div id="met-avance" class="metrica-valor">—</div><div id="met-avance-detalle" class="metrica-cambio positivo">—</div></div>
        <div class="carta-metrica amarillo"><div class="metrica-icono">💰</div><div class="metrica-etiqueta">Saldo pendiente</div><div id="met-saldo" class="metrica-valor">—</div><div id="met-saldo-info" class="metrica-cambio negativo"></div></div>
      </div>

      <div class="grid-2">
        <!-- Cursos actuales -->
        <div class="carta">
          <div class="carta-cabecera">
            <div><div class="carta-titulo">Mis cursos</div><div id="sub-cursos-periodo" class="carta-subtitulo">—</div></div>
            <a href="/enrollment/mi-matricula" class="btn btn-secundario btn-sm">Ver matrícula</a>
          </div>
          <div id="lista-mis-cursos" class="carta-cuerpo" style="padding:0;">
            <div style="padding:2rem;text-align:center;color:var(--gris-suave);">Cargando cursos…</div>
          </div>
        </div>

        <!-- Notificaciones y accesos rápidos -->
        <div style="display:flex;flex-direction:column;gap:1.25rem;">
          <div class="carta">
            <div class="carta-cabecera"><div class="carta-titulo">Notificaciones recientes</div><a href="/notifications" class="btn btn-texto btn-sm">Ver todas</a></div>
            <div id="lista-notif-recientes" style="padding:.5rem 0;">
              <div style="padding:1.5rem;text-align:center;color:var(--gris-suave);">Cargando…</div>
            </div>
          </div>

          <div class="carta">
            <div class="carta-cabecera"><div class="carta-titulo">Acceso rápido</div></div>
            <div class="carta-cuerpo" style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
              <a href="/enrollment/buscar" style="display:flex;flex-direction:column;align-items:center;gap:.5rem;padding:1rem;background:var(--gris-fondo);border-radius:var(--radio-borde);text-decoration:none;text-align:center;" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background='var(--gris-fondo)'">
                <span style="font-size:1.5rem;">🔍</span><span style="font-size:.8125rem;font-weight:600;color:var(--gris-oscuro);">Buscar cursos</span>
              </a>
              <a href="/billing/pagar" style="display:flex;flex-direction:column;align-items:center;gap:.5rem;padding:1rem;background:var(--gris-fondo);border-radius:var(--radio-borde);text-decoration:none;text-align:center;" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background='var(--gris-fondo)'">
                <span style="font-size:1.5rem;">💳</span><span style="font-size:.8125rem;font-weight:600;color:var(--gris-oscuro);">Realizar pago</span>
              </a>
              <a href="/enrollment/comprobante" style="display:flex;flex-direction:column;align-items:center;gap:.5rem;padding:1rem;background:var(--gris-fondo);border-radius:var(--radio-borde);text-decoration:none;text-align:center;" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background='var(--gris-fondo)'">
                <span style="font-size:1.5rem;">🖨️</span><span style="font-size:.8125rem;font-weight:600;color:var(--gris-oscuro);">Comprobante</span>
              </a>
              <a href="/students/historial" style="display:flex;flex-direction:column;align-items:center;gap:.5rem;padding:1rem;background:var(--gris-fondo);border-radius:var(--radio-borde);text-decoration:none;text-align:center;" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background='var(--gris-fondo)'">
                <span style="font-size:1.5rem;">📊</span><span style="font-size:.8125rem;font-weight:600;color:var(--gris-oscuro);">Historial</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
<script>window._idEstudiante = {{id_estudiante}};</script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/students-dashboard.js"></script>