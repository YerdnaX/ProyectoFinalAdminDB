      </div>
    </header>

    <main class="area-pagina">
      <!-- Saludo -->
      <div style="background:linear-gradient(135deg,var(--verde-principal),var(--verde-hover));border-radius:var(--radio-grande);padding:2rem;color:#fff;margin-bottom:1.75rem;">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
          <div>
            <h2 style="color:#fff;margin-bottom:.375rem;">¡Buenos días, Laura! 👋</h2>
            <p style="color:rgba(255,255,255,.85);margin:0;">I Semestre 2025 — Matrícula confirmada con 4 cursos y 12 créditos.</p>
          </div>
          <a href="../enrollment/buscar-cursos.html" class="btn" style="background:rgba(255,255,255,.2);color:#fff;border:1px solid rgba(255,255,255,.4);">Buscar más cursos →</a>
        </div>
      </div>

      <!-- Alertas -->
      <div class="alerta alerta-alerta mb-4">
        <span class="alerta-icono">⚠️</span>
        <div><span class="alerta-titulo">Pago pendiente:</span> Tienes una factura por <strong>₡185,000</strong> con vencimiento el <strong>31 de enero 2025</strong>. <a href="../billing/realizar-pago.html">Pagar ahora →</a></div>
      </div>

      <!-- Métricas estudiante -->
      <div class="grid-metricas mb-4">
        <div class="carta-metrica"><div class="metrica-icono">📚</div><div class="metrica-etiqueta">Cursos matriculados</div><div class="metrica-valor">4</div><div class="metrica-cambio positivo">I Semestre 2025</div></div>
        <div class="carta-metrica"><div class="metrica-icono">⭐</div><div class="metrica-etiqueta">Créditos actuales</div><div class="metrica-valor">12</div><div class="metrica-cambio positivo">Límite: 20</div></div>
        <div class="carta-metrica azul"><div class="metrica-icono">🎯</div><div class="metrica-etiqueta">Avance del plan</div><div class="metrica-valor">30%</div><div class="metrica-cambio positivo">48 / 160 créditos</div></div>
        <div class="carta-metrica amarillo"><div class="metrica-icono">💰</div><div class="metrica-etiqueta">Saldo pendiente</div><div class="metrica-valor">₡185K</div><div class="metrica-cambio negativo">▼ Vence 31 ene</div></div>
      </div>

      <div class="grid-2">
        <!-- Cursos actuales -->
        <div class="carta">
          <div class="carta-cabecera">
            <div><div class="carta-titulo">Mis cursos</div><div class="carta-subtitulo">I Semestre 2025</div></div>
            <a href="../enrollment/mi-matricula.html" class="btn btn-secundario btn-sm">Ver matrícula</a>
          </div>
          <div class="carta-cuerpo" style="padding:0;">
            <div style="padding:1rem 1.5rem;border-bottom:1px solid var(--gris-linea);">
              <div style="display:flex;align-items:center;justify-content:space-between;">
                <div>
                  <div style="font-size:.75rem;font-weight:700;color:var(--verde-principal);">IS-2201</div>
                  <div style="font-weight:600;">Estructuras de Datos</div>
                  <div class="texto-pequeno">L-Mi 7:00–9:00 · A-204</div>
                </div>
                <span class="badge badge-confirmado">4 créditos</span>
              </div>
            </div>
            <div style="padding:1rem 1.5rem;border-bottom:1px solid var(--gris-linea);">
              <div style="display:flex;align-items:center;justify-content:space-between;">
                <div>
                  <div style="font-size:.75rem;font-weight:700;color:var(--verde-principal);">IS-2202</div>
                  <div style="font-weight:600;">Base de Datos I</div>
                  <div class="texto-pequeno">Ma-Ju 9:00–10:30 · Virtual</div>
                </div>
                <span class="badge badge-confirmado">3 créditos</span>
              </div>
            </div>
            <div style="padding:1rem 1.5rem;border-bottom:1px solid var(--gris-linea);">
              <div style="display:flex;align-items:center;justify-content:space-between;">
                <div>
                  <div style="font-size:.75rem;font-weight:700;color:var(--verde-principal);">MAT-1501</div>
                  <div style="font-weight:600;">Cálculo I</div>
                  <div class="texto-pequeno">L-Mi-Vi 10:00–11:00 · B-201</div>
                </div>
                <span class="badge badge-confirmado">4 créditos</span>
              </div>
            </div>
            <div style="padding:1rem 1.5rem;">
              <div style="display:flex;align-items:center;justify-content:space-between;">
                <div>
                  <div style="font-size:.75rem;font-weight:700;color:var(--verde-principal);">ING-1001</div>
                  <div style="font-weight:600;">Inglés Técnico I</div>
                  <div class="texto-pequeno">Vi 13:00–15:00 · A-105</div>
                </div>
                <span class="badge badge-confirmado">1 crédito</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Notificaciones y accesos rápidos -->
        <div style="display:flex;flex-direction:column;gap:1.25rem;">
          <div class="carta">
            <div class="carta-cabecera"><div class="carta-titulo">Notificaciones recientes</div><a href="../notifications/notificaciones-lista.html" class="btn btn-texto btn-sm">Ver todas</a></div>
            <div style="padding:.5rem 0;">
              <div style="padding:.875rem 1.5rem;display:flex;gap:.875rem;align-items:flex-start;border-bottom:1px solid var(--gris-linea);">
                <span style="font-size:1.2rem;">💳</span>
                <div>
                  <div style="font-size:.875rem;font-weight:600;">Factura F-2025-00812 emitida</div>
                  <div class="texto-pequeno">Monto: ₡185,000 — Vence 31/01/2025</div>
                  <div class="texto-pequeno" style="margin-top:.125rem;color:var(--gris-suave);">hace 2 horas</div>
                </div>
              </div>
              <div style="padding:.875rem 1.5rem;display:flex;gap:.875rem;align-items:flex-start;">
                <span style="font-size:1.2rem;">✅</span>
                <div>
                  <div style="font-size:.875rem;font-weight:600;">Matrícula confirmada</div>
