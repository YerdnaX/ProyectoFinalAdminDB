      <div class="sidebar-seccion">Matrícula</div>
      <a href="../enrollment/buscar-cursos.html"><span class="icono">🔍</span> Buscar cursos</a>
      <a href="../enrollment/mi-matricula.html"><span class="icono">✏️</span> Mi matrícula</a>
      <a href="../enrollment/comprobante.html"><span class="icono">🖨️</span> Comprobante</a>
