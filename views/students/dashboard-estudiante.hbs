                </div>
              </div>
            </div>
          </div>

          <div class="carta">
            <div class="carta-cabecera"><div class="carta-titulo">Acceso rápido</div></div>
            <div class="carta-cuerpo" style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;">
              <a href="../enrollment/buscar-cursos.html" style="display:flex;flex-direction:column;align-items:center;gap:.5rem;padding:1rem;background:var(--gris-fondo);border-radius:var(--radio-borde);text-decoration:none;text-align:center;" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background='var(--gris-fondo)'">
                <span style="font-size:1.5rem;">🔍</span><span style="font-size:.8125rem;font-weight:600;color:var(--gris-oscuro);">Buscar cursos</span>
              </a>
              <a href="../billing/realizar-pago.html" style="display:flex;flex-direction:column;align-items:center;gap:.5rem;padding:1rem;background:var(--gris-fondo);border-radius:var(--radio-borde);text-decoration:none;text-align:center;" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background='var(--gris-fondo)'">
                <span style="font-size:1.5rem;">💳</span><span style="font-size:.8125rem;font-weight:600;color:var(--gris-oscuro);">Realizar pago</span>
              </a>
              <a href="../enrollment/comprobante.html" style="display:flex;flex-direction:column;align-items:center;gap:.5rem;padding:1rem;background:var(--gris-fondo);border-radius:var(--radio-borde);text-decoration:none;text-align:center;" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background='var(--gris-fondo)'">
                <span style="font-size:1.5rem;">🖨️</span><span style="font-size:.8125rem;font-weight:600;color:var(--gris-oscuro);">Comprobante</span>
              </a>
              <a href="../students/historial-academico.html" style="display:flex;flex-direction:column;align-items:center;gap:.5rem;padding:1rem;background:var(--gris-fondo);border-radius:var(--radio-borde);text-decoration:none;text-align:center;" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background='var(--gris-fondo)'">
                <span style="font-size:1.5rem;">📊</span><span style="font-size:.8125rem;font-weight:600;color:var(--gris-oscuro);">Historial</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
