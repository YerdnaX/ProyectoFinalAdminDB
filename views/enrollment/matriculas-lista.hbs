<div class="app-wrapper">
  {{> sidebar-admin}}
  <div class="contenido-principal">
    <header class="navbar">
      <div><div class="navbar-titulo">MatrГӯculas</div><div class="navbar-breadcrumb"><span>Inicio</span><span class="separador"></span><span class="actual">MatrГӯculas</span></div></div>
      <div class="navbar-acciones"><div class="navbar-usuario"><div class="avatar">AM</div><div><div class="navbar-usuario-nombre">Ana Mora</div><div class="navbar-usuario-rol">Administradora TI</div></div></div></div>
    </header>
    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>GestiГіn de matrГӯculas</h1><p>Consulta y administra todas las matrГӯculas del I Semestre 2025.</p></div>
        <div class="acciones-encabezado"><a id="btn-exportar-matriculas" href="/api/reports/export/matriculas" class="btn btn-secundario">Exportar CSV</a></div>
      </div>
      <div class="grid-4 mb-4">
        <div class="carta-metrica"><div class="metrica-icono">вңҸпёҸ</div><div class="metrica-etiqueta">Total matrГӯculas</div><div class="metrica-valor" id="met-total">вҖ”</div></div>
        <div class="carta-metrica"><div class="metrica-icono">вң…</div><div class="metrica-etiqueta">Confirmadas</div><div class="metrica-valor" id="met-confirmadas">вҖ”</div><div class="metrica-cambio positivo" id="met-pct-conf"></div></div>
        <div class="carta-metrica amarillo"><div class="metrica-icono">вҸі</div><div class="metrica-etiqueta">En proceso</div><div class="metrica-valor" id="met-proceso">вҖ”</div></div>
        <div class="carta-metrica rojo"><div class="metrica-icono">вқҢ</div><div class="metrica-etiqueta">Canceladas</div><div class="metrica-valor" id="met-canceladas">вҖ”</div></div>
      </div>
      <div class="carta">
        <div class="carta-cabecera">
          <div class="barra-filtros" style="margin:0;flex:1;">
            <div class="barra-busqueda"><span class="icono-buscar">рҹ”Қ</span><input id="fil-buscar" type="text" placeholder="Buscar por nombre o carnй..."></div>
            <select id="sel-estado" class="filtro-select"><option value="">Todos los estados</option><option value="Confirmada">Confirmada</option><option value="En proceso">En proceso</option><option value="Cancelada">Cancelada</option></select>
            <select id="sel-periodo" class="filtro-select"><option value="">Todos los periodos</option></select>
            <button id="btn-buscar" class="btn btn-primario btn-sm">Buscar</button>
          </div>
        </div>
        <div class="tabla-contenedor">
          <table class="tabla">
            <thead><tr><th>Comprobante</th><th>Estudiante</th><th>Fecha</th><th>Cursos</th><th>CrГ©ditos</th><th>Monto</th><th>Estado</th></tr></thead>
            <tbody id="tbody-matriculas">
              <tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--gris-suave);">CargandoвҖҰ</td></tr>
            </tbody>
          </table>
        </div>
        <div id="paginacion-matriculas" class="paginacion"></div>
      </div>
    </main>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/enrollment-lista.js"></script>
