<div class="app-wrapper">
  <aside class="sidebar">
    <div class="sidebar-logo"><div class="sidebar-logo-icono">🎓</div><div><div class="sidebar-logo-texto">UniMatrícula</div><div class="sidebar-logo-subtexto">Portal Estudiantil</div></div></div>
    <nav class="sidebar-nav">
      <div class="sidebar-seccion">General</div>
      <a href="/students"><span class="icono">🏠</span> Mi portal</a>
      <div class="sidebar-seccion">Matrícula</div>
      <a href="/enrollment/buscar" class="activo"><span class="icono">🔍</span> Buscar cursos</a>
      <a href="/enrollment/mi-matricula"><span class="icono">✏️</span> Mi matrícula</a>
      <a href="/enrollment/comprobante"><span class="icono">🖨️</span> Comprobante</a>
      <div class="sidebar-seccion">Mi información</div>
      <a href="/students/mi-perfil"><span class="icono">👤</span> Mi perfil</a>
      <a href="/students/historial"><span class="icono">📊</span> Historial académico</a>
      <div class="sidebar-seccion">Finanzas</div>
      <a href="/billing/estado-cuenta"><span class="icono">📄</span> Estado de cuenta</a>
      <a href="/billing/mis-facturas"><span class="icono">🧾</span> Mis facturas</a>
      <a href="/billing/pagar"><span class="icono">💳</span> Realizar pago</a>
      <div class="sidebar-seccion">Comunicaciones</div>
      <a href="/notifications"><span class="icono">🔔</span> Notificaciones</a>
    </nav>
    <div class="sidebar-footer"><a href="/auth/logout">🚪 Cerrar sesión</a></div>
  </aside>

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Buscar Cursos</div>
        <div class="navbar-breadcrumb"><a href="/students">Inicio</a><span class="separador"></span><span class="actual">Buscar cursos</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="icono-notif">🔔<span class="badge-notif">2</span></div>
        <div class="navbar-usuario"><div class="avatar">LJ</div><div><div class="navbar-usuario-nombre">Laura Jiménez</div><div class="navbar-usuario-rol">Estudiante · 2024-0312</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Oferta académica</h1><p>I Semestre 2025 — Selecciona los cursos que deseas matricular.</p></div>
        <div class="acciones-encabezado">
          <div style="background:var(--verde-bg);border:1px solid var(--verde-claro);border-radius:var(--radio-borde);padding:.5rem 1rem;font-size:.875rem;display:flex;align-items:center;gap:.5rem;">
            <span>✏️</span>
            <span>Cursos seleccionados: <strong>2</strong> / Créditos: <strong>7 / 20</strong></span>
          </div>
          <a href="/enrollment/mi-matricula" class="btn btn-primario">Ver mi selección →</a>
        </div>
      </div>

      <!-- Restricciones activas -->
      <div class="alerta alerta-info mb-4">
        <span class="alerta-icono">ℹ️</span>
        <div><span class="alerta-titulo">Límite de créditos:</span> Puedes matricular hasta <strong>20 créditos</strong> en este periodo. Llevas 7 créditos seleccionados. El sistema validará automáticamente prerrequisitos, cupos y conflictos de horario.</div>
      </div>

      <!-- Filtros -->
      <div class="carta mb-4">
        <div class="carta-cuerpo">
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr auto;gap:1rem;align-items:end;">
            <div class="campo" style="margin:0;">
              <label>Buscar</label>
              <div class="barra-busqueda" style="min-width:0;"><span class="icono-buscar">🔍</span><input id="input-buscar" type="text" placeholder="Nombre o código..."></div>
            </div>
            <div class="campo" style="margin:0;">
              <label>Programa</label>
              <select id="sel-programa" class="campo-input">
                <option value="">Todos los programas</option>
              </select>
            </div>
            <button id="btn-buscar" class="btn btn-primario">Buscar</button>
          </div>
        </div>
      </div>

      <!-- Tabla de secciones disponibles -->
      <div class="carta">
        <div class="tabla-contenedor">
          <table class="tabla">
            <thead><tr><th>Código</th><th>Curso / Programa</th><th>Sección</th><th>Docente</th><th>Horario</th><th>Cupos</th><th></th></tr></thead>
            <tbody id="tbody-secciones">
              <tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--gris-suave);">Cargando secciones…</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <div style="margin-top:1.5rem;text-align:center;">
        <a href="/enrollment/mi-matricula" class="btn btn-primario btn-lg">Ver mi selección →</a>
      </div>
    </main>
  </div>
</div>
<script>window._idEstudiante = {{id_estudiante}};</script>
