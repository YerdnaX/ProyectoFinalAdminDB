<div class="app-wrapper">
  <aside class="sidebar">
    <div class="sidebar-logo"><div class="sidebar-logo-icono">🎓</div><div><div class="sidebar-logo-texto">UniMatrícula</div><div class="sidebar-logo-subtexto">Portal Estudiantil</div></div></div>
    <nav class="sidebar-nav">
      <div class="sidebar-seccion">General</div>
      <a href="/students"><span class="icono">🏠</span> Mi portal</a>
      <div class="sidebar-seccion">Matrícula</div>
      <a href="/enrollment/buscar"><span class="icono">🔍</span> Buscar cursos</a>
      <a href="/enrollment/mi-matricula" class="activo"><span class="icono">✏️</span> Mi matrícula</a>
      <a href="/enrollment/comprobante"><span class="icono">🖨️</span> Comprobante</a>
      <div class="sidebar-seccion">Mi información</div>
      <a href="/students/mi-perfil"><span class="icono">👤</span> Mi perfil</a>
      <a href="/students/historial"><span class="icono">📊</span> Historial académico</a>
      <div class="sidebar-seccion">Finanzas</div>
      <a href="/billing/estado-cuenta"><span class="icono">📄</span> Estado de cuenta</a>
      <a href="/billing/mis-facturas"><span class="icono">🧾</span> Mis facturas</a>
      <a href="/billing/pagar"><span class="icono">💳</span> Realizar pago</a>
      <div class="sidebar-seccion">Comunicaciones</div>
      <a href="/notifications"><span class="icono">🔔</span> Notificaciones</a>
    </nav>
    <div class="sidebar-footer"><a href="/auth/logout">🚪 Cerrar sesión</a></div>
  </aside>

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Mi Matrícula</div>
        <div class="navbar-breadcrumb"><a href="/students">Inicio</a><span class="separador"></span><span class="actual">Mi matrícula</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="navbar-usuario"><div class="avatar">LJ</div><div><div class="navbar-usuario-nombre">Laura Jiménez</div><div class="navbar-usuario-rol">Estudiante · 2024-0312</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <!-- Pasos del proceso -->
      <div class="pasos mb-5">
        <div class="paso completado"><div class="paso-num">✓</div><span class="paso-etiqueta">Selección</span></div>
        <div class="paso activo"><div class="paso-num">2</div><span class="paso-etiqueta">Resumen</span></div>
        <div class="paso"><div class="paso-num">3</div><span class="paso-etiqueta">Pago</span></div>
        <div class="paso"><div class="paso-num">4</div><span class="paso-etiqueta">Confirmación</span></div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 340px;gap:1.5rem;">
        <div>
          <h2 style="margin-bottom:1.25rem;">Resumen de matrícula</h2>

          <div class="carta mb-4">
            <div class="carta-cabecera">
              <div><div class="carta-titulo">Cursos seleccionados</div><div class="carta-subtitulo" id="sub-matricula">Cargando…</div></div>
              <a href="/enrollment/buscar" class="btn btn-secundario btn-sm">Modificar</a>
            </div>
            <div class="tabla-contenedor">
              <table class="tabla">
                <thead><tr><th>Código</th><th>Curso</th><th>Sección</th><th>Horario</th><th>Créditos</th><th>Costo</th><th></th></tr></thead>
                <tbody id="tbody-matricula">
                  <tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--gris-suave);">Cargando…</td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Validaciones -->
          <div class="carta">
            <div class="carta-cabecera"><div class="carta-titulo">Validaciones del sistema</div></div>
            <div class="carta-cuerpo">
              <div id="validaciones-lista" style="display:flex;flex-direction:column;gap:.75rem;">
                <div style="text-align:center;color:var(--gris-suave);">Cargando validaciones…</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Panel de pago -->
        <div>
          <div class="carta mb-3">
            <div class="carta-cabecera"><div class="carta-titulo">Resumen de cobro</div></div>
            <div class="carta-cuerpo">
              <div style="display:flex;flex-direction:column;gap:.75rem;font-size:.9rem;">
                <div class="flex-entre"><span class="texto-gris">Estructuras de Datos (4 cr.)</span><span>₡56,000</span></div>
                <div class="flex-entre"><span class="texto-gris">Base de Datos I (3 cr.)</span><span>₡42,000</span></div>
                <div class="flex-entre"><span class="texto-gris">Cálculo I (4 cr.)</span><span>₡56,000</span></div>
                <div class="flex-entre"><span class="texto-gris">Inglés Técnico I (1 cr.)</span><span>₡14,000</span></div>
                <hr class="divisor" style="margin:.25rem 0;">
                <div class="flex-entre"><span class="texto-gris">Subtotal</span><span style="font-weight:600;">₡168,000</span></div>
                <div class="flex-entre"><span class="texto-gris">Descuentos</span><span style="color:var(--cyan-exito);">−₡0</span></div>
                <div class="flex-entre"><span class="texto-gris">Recargos</span><span>₡17,000</span></div>
                <div class="flex-entre"><span class="texto-gris">Saldo anterior</span><span style="color:var(--rojo-peligro);">₡0</span></div>
                <hr class="divisor" style="margin:.25rem 0;">
                <div class="flex-entre" style="font-size:1.1rem;"><strong>Total a pagar</strong><strong style="color:var(--verde-principal);">₡185,000</strong></div>
              </div>
            </div>
          </div>

          <div class="carta mb-3">
            <div class="carta-cuerpo">
              <div class="campo">
                <label>Método de pago</label>
                <select class="campo-input">
                  <option>Tarjeta de crédito / débito</option>
                  <option>Transferencia bancaria</option>
                  <option>Pago en caja</option>
                </select>
              </div>
              <div class="alerta alerta-info" style="font-size:.8125rem;">
                <span>🔒</span>
                <span>Tu pago es procesado de forma segura a través de la pasarela institucional.</span>
              </div>
            </div>
          </div>

          <div class="carta">
            <div class="carta-cuerpo">
              <button id="btn-confirmar" class="btn btn-primario w-full btn-lg mb-2">Confirmar matrícula</button>
              <span id="estado-matricula" style="display:block;text-align:center;font-size:.8rem;color:var(--gris-suave);margin-bottom:.75rem;"></span>
              <a href="/enrollment/buscar" class="btn btn-secundario w-full" style="display:flex;align-items:center;justify-content:center;">← Modificar selección</a>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
<script>window._idEstudiante = {{id_estudiante}};</script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/enrollment-matricula.js"></script>