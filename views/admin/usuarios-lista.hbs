<div class="app-wrapper">
  {{> sidebar-admin}}

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Gestión de Usuarios</div>
        <div class="navbar-breadcrumb"><span>Inicio</span><span class="separador"></span><span class="actual">Usuarios</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="icono-notif">🔔<span class="badge-notif">4</span></div>
        <div class="navbar-usuario"><div class="avatar">AM</div><div><div class="navbar-usuario-nombre">Ana Mora</div><div class="navbar-usuario-rol">Administradora TI</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Usuarios del sistema</h1><p>Gestiona cuentas de estudiantes, docentes y personal administrativo.</p></div>
        <div class="acciones-encabezado">
          <a href="/admin/usuarios/nuevo" class="btn btn-primario">+ Nuevo usuario</a>
        </div>
      </div>

      <div class="carta">
        <div class="carta-cabecera">
          <div class="barra-filtros" style="margin:0;flex:1;">
            <div class="barra-busqueda">
              <span class="icono-buscar">🔍</span>
              <input id="input-buscar" type="text" placeholder="Buscar por nombre, correo o identificador...">
            </div>
            <select id="sel-rol" class="filtro-select">
              <option value="">Todos los roles</option>
              <option>Estudiante</option>
              <option>Docente</option>
              <option>Registro Académico</option>
              <option>Tesorería</option>
              <option>Administrador TI</option>
              <option>Auditor</option>
            </select>
            <select id="sel-estado" class="filtro-select">
              <option value="">Todos los estados</option>
              <option value="1">Activo</option>
              <option value="0">Inactivo</option>
            </select>
          </div>
        </div>

        <div class="tabla-contenedor">
          <table class="tabla">
            <thead>
              <tr>
                <th>Usuario</th>
                <th>Identificador SSO</th>
                <th>Rol</th>
                <th>Estado</th>
                <th>Fecha creación</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody id="tbody-usuarios">
              <tr><td colspan="6" style="text-align:center;padding:2rem;color:var(--gris-suave);">Cargando…</td></tr>
            </tbody>
          </table>
        </div>
        <div id="paginacion-usuarios" class="paginacion"></div>
      </div>
    </main>
  </div>
</div>

<!-- Modal: Crear usuario -->
<div id="modal-crear" class="modal" style="display:none;" onclick="if(event.target===this)U.closeModal('modal-crear')">
  <div class="modal-caja" style="max-width:480px;" onclick="event.stopPropagation()">
    <div class="modal-cabecera"><h3>Nuevo usuario</h3><button onclick="U.closeModal('modal-crear')" style="background:none;border:none;font-size:1.5rem;cursor:pointer;">×</button></div>
    <form id="form-crear-usuario" style="padding:1.25rem;display:flex;flex-direction:column;gap:1rem;">
      <div class="campo"><label>Nombre</label><input class="campo-input" name="nombre" required></div>
      <div class="campo"><label>Apellido</label><input class="campo-input" name="apellido" required></div>
      <div class="campo"><label>Correo</label><input class="campo-input" type="email" name="correo" required></div>
      <div class="campo"><label>Contraseña</label><input class="campo-input" type="password" name="contrasena" required></div>
      <div class="campo"><label>Identificador SSO <span class="requerido">*</span></label><input class="campo-input" name="identificador_sso" required></div>
      <div class="campo"><label>Rol</label>
        <select class="campo-input" name="id_rol" required>
          <option value="">Seleccionar…</option>
        </select>
      </div>
      <div class="campo bloque-estudiante" style="display:none;">
        <label>Programa académico <span class="requerido">*</span></label>
        <select class="campo-input" name="id_programa">
          <option value="">Seleccionar programa...</option>
        </select>
      </div>
      <div class="campo bloque-estudiante" style="display:none;">
        <label>Carné (opcional)</label>
        <input class="campo-input" name="carne" placeholder="Se genera automáticamente si se deja vacío">
      </div>
      <div style="display:flex;gap:.75rem;justify-content:flex-end;">
        <button type="button" onclick="U.closeModal('modal-crear')" class="btn btn-secundario">Cancelar</button>
        <button type="submit" class="btn btn-primario">Crear usuario</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal: Editar usuario -->
<div id="modal-editar" class="modal" style="display:none;" onclick="if(event.target===this)U.closeModal('modal-editar')">
  <div class="modal-caja" style="max-width:480px;" onclick="event.stopPropagation()">
    <div class="modal-cabecera"><h3>Editar usuario</h3><button onclick="U.closeModal('modal-editar')" style="background:none;border:none;font-size:1.5rem;cursor:pointer;">×</button></div>
    <form id="form-editar-usuario" style="padding:1.25rem;display:flex;flex-direction:column;gap:1rem;">
      <div class="campo"><label>Nombre</label><input class="campo-input" name="nombre" required></div>
      <div class="campo"><label>Apellido</label><input class="campo-input" name="apellido" required></div>
      <div class="campo"><label>Correo</label><input class="campo-input" type="email" name="correo" required></div>
      <div class="campo"><label>Rol</label>
        <select class="campo-input" name="id_rol" required>
          <option value="">Seleccionar…</option>
        </select>
      </div>
      <div class="campo bloque-estudiante" style="display:none;">
        <label>Programa académico <span class="requerido">*</span></label>
        <select class="campo-input" name="id_programa">
          <option value="">Seleccionar programa...</option>
        </select>
      </div>
      <div class="campo bloque-estudiante" style="display:none;">
        <label>Carné (opcional)</label>
        <input class="campo-input" name="carne" placeholder="Actualizar carné (opcional)">
      </div>
      <div style="display:flex;gap:.75rem;justify-content:flex-end;">
        <button type="button" onclick="U.closeModal('modal-editar')" class="btn btn-secundario">Cancelar</button>
        <button type="submit" class="btn btn-primario">Guardar cambios</button>
      </div>
    </form>
  </div>
</div>

<style>
.modal { position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;display:flex!important;align-items:center;justify-content:center; visibility:hidden;opacity:0;transition:.2s; }
.modal.abierto { visibility:visible;opacity:1; }
.modal-caja { background:#fff;border-radius:12px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,.2); }
.modal-cabecera { display:flex;justify-content:space-between;align-items:center;padding:1rem 1.25rem;border-bottom:1px solid var(--gris-linea); }
</style>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script>
  document.querySelector('.btn-primario[href="/admin/usuarios/nuevo"]')?.addEventListener('click', e => {
    e.preventDefault(); U.openModal('modal-crear');
  });
  // también capturar el botón "+ Nuevo usuario" que es un <a>
  document.querySelector('a[href="/admin/usuarios/nuevo"]')?.addEventListener('click', e => {
    e.preventDefault(); U.openModal('modal-crear');
  });
</script>
<script src="/js/admin-usuarios.js"></script>
