<!-- Modal: Crear usuario -->
<div id="modal-crear" class="modal" style="display:none;" onclick="if(event.target===this)U.closeModal('modal-crear')">
  <div class="modal-caja" style="max-width:480px;" onclick="event.stopPropagation()">
    <div class="modal-cabecera"><h3>Nuevo usuario</h3><button onclick="U.closeModal('modal-crear')" style="background:none;border:none;font-size:1.5rem;cursor:pointer;">×</button></div>
    <form id="form-crear-usuario" style="padding:1.25rem;display:flex;flex-direction:column;gap:1rem;">
      <div class="campo"><label>Nombre</label><input class="campo-input" name="nombre" required></div>
      <div class="campo"><label>Apellido</label><input class="campo-input" name="apellido" required></div>
      <div class="campo"><label>Correo</label><input class="campo-input" type="email" name="correo" required></div>
      <div class="campo"><label>Contraseña</label><input class="campo-input" type="password" name="password_hash" required></div>
      <div class="campo"><label>Identificador SSO</label><input class="campo-input" name="identificador_sso"></div>
      <div class="campo"><label>Rol</label>
        <select class="campo-input" name="id_rol" required>
          <option value="">Seleccionar…</option>
        </select>
      </div>
      <div style="display:flex;gap:.75rem;justify-content:flex-end;">
        <button type="button" onclick="U.closeModal('modal-crear')" class="btn btn-secundario">Cancelar</button>
        <button type="submit" class="btn btn-primario">Crear usuario</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal: Editar usuario -->
<div id="modal-editar" class="modal" style="display:none;" onclick="if(event.target===this)U.closeModal('modal-editar')">
  <div class="modal-caja" style="max-width:480px;" onclick="event.stopPropagation()">
    <div class="modal-cabecera"><h3>Editar usuario</h3><button onclick="U.closeModal('modal-editar')" style="background:none;border:none;font-size:1.5rem;cursor:pointer;">×</button></div>
    <form id="form-editar-usuario" style="padding:1.25rem;display:flex;flex-direction:column;gap:1rem;">
      <div class="campo"><label>Nombre</label><input class="campo-input" name="nombre" required></div>
      <div class="campo"><label>Apellido</label><input class="campo-input" name="apellido" required></div>
      <div class="campo"><label>Correo</label><input class="campo-input" type="email" name="correo" required></div>
      <div class="campo"><label>Rol</label>
        <select class="campo-input" name="id_rol" required>
          <option value="">Seleccionar…</option>
        </select>
      </div>
      <div style="display:flex;gap:.75rem;justify-content:flex-end;">
        <button type="button" onclick="U.closeModal('modal-editar')" class="btn btn-secundario">Cancelar</button>
        <button type="submit" class="btn btn-primario">Guardar cambios</button>
      </div>
    </form>
  </div>
</div>

<style>
.modal { position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;display:flex!important;align-items:center;justify-content:center; visibility:hidden;opacity:0;transition:.2s; }
.modal.abierto { visibility:visible;opacity:1; }
.modal-caja { background:#fff;border-radius:12px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,.2); }
.modal-cabecera { display:flex;justify-content:space-between;align-items:center;padding:1rem 1.25rem;border-bottom:1px solid var(--gris-linea); }
</style>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script>
  document.querySelector('.btn-primario[href="/admin/usuarios/nuevo"]')?.addEventListener('click', e => {
    e.preventDefault(); U.openModal('modal-crear');
  });
  // también capturar el botón "+ Nuevo usuario" que es un <a>
  document.querySelector('a[href="/admin/usuarios/nuevo"]')?.addEventListener('click', e => {
    e.preventDefault(); U.openModal('modal-crear');
  });
</script>
<script src="/js/admin-usuarios.js"></script>