  </aside>

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Roles y Permisos</div>
        <div class="navbar-breadcrumb"><span>Inicio</span><span class="separador"></span><span class="actual">Roles y permisos</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="navbar-usuario"><div class="avatar">AM</div><div><div class="navbar-usuario-nombre">Ana Mora</div><div class="navbar-usuario-rol">Administradora TI</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Roles y permisos</h1><p>Define qué acciones puede realizar cada rol dentro del sistema.</p></div>
        <div class="acciones-encabezado"><button id="btn-nuevo-rol" class="btn btn-primario">+ Nuevo rol</button></div>
      </div>

      <div style="display:grid;grid-template-columns:260px 1fr;gap:1.5rem;">
        <!-- Lista de roles -->
        <div class="carta" style="height:fit-content;">
          <div class="carta-cabecera"><div class="carta-titulo">Roles definidos</div></div>
          <div id="lista-roles" style="padding:.5rem 0;">
            <div style="padding:1.5rem;text-align:center;color:var(--gris-suave);">Cargando…</div>
          </div>
        </div>

        <!-- Permisos del rol seleccionado -->
        <div class="carta">
          <div class="carta-cabecera">
            <div>
              <div id="permisos-titulo" class="carta-titulo">Permisos — Rol: —</div>
              <div class="carta-subtitulo">Define qué módulos y acciones puede realizar este rol</div>
            </div>
            <button id="btn-guardar-permisos" class="btn btn-primario btn-sm">Guardar cambios</button>
          </div>
          <div class="carta-cuerpo">
            <div class="alerta alerta-alerta mb-4">
              <span class="alerta-icono">⚠️</span>
              <div>Los cambios en permisos afectan a <strong>todos los usuarios</strong> con este rol. Procede con cuidado.</div>
            </div>

            <!-- Módulo de permisos -->
            <div style="display:flex;flex-direction:column;gap:1rem;">
              <!-- Matrícula -->
              <div class="campo-grupo">
                <div class="campo-grupo-titulo">📚 Matrícula</div>
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.625rem;">
                  <label class="campo-checkbox"><input type="checkbox" checked> Ver oferta académica</label>
                  <label class="campo-checkbox"><input type="checkbox" checked> Realizar matrícula</label>
                  <label class="campo-checkbox"><input type="checkbox" checked> Ver comprobante</label>
                  <label class="campo-checkbox"><input type="checkbox"> Modificar matrícula confirmada</label>
                </div>
              </div>
              <!-- Perfil -->
              <div class="campo-grupo">
                <div class="campo-grupo-titulo">👤 Perfil personal</div>
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.625rem;">
                  <label class="campo-checkbox"><input type="checkbox" checked> Ver propio perfil</label>
                  <label class="campo-checkbox"><input type="checkbox" checked> Ver historial académico</label>
                  <label class="campo-checkbox"><input type="checkbox"> Editar datos personales</label>
                </div>
              </div>
              <!-- Pagos -->
              <div class="campo-grupo">
                <div class="campo-grupo-titulo">💳 Pagos y facturación</div>
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.625rem;">
                  <label class="campo-checkbox"><input type="checkbox" checked> Ver estado de cuenta</label>
                  <label class="campo-checkbox"><input type="checkbox" checked> Ver facturas propias</label>
                  <label class="campo-checkbox"><input type="checkbox" checked> Realizar pagos</label>
                  <label class="campo-checkbox"><input type="checkbox"> Descargar comprobantes</label>
                </div>
              </div>
              <!-- Notificaciones -->
              <div class="campo-grupo">
                <div class="campo-grupo-titulo">🔔 Notificaciones</div>
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.625rem;">
                  <label class="campo-checkbox"><input type="checkbox" checked> Ver propias notificaciones</label>
                  <label class="campo-checkbox"><input type="checkbox"> Marcar como leídas</label>
                </div>
              </div>
              <!-- Acceso denegado -->
              <div class="campo-grupo" style="border-color:var(--rojo-peligro-bg);">
                <div class="campo-grupo-titulo" style="color:var(--rojo-peligro);">🚫 Acceso restringido (no aplica para Estudiante)</div>
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:.625rem;">
                  <label class="campo-checkbox"><input type="checkbox" disabled> Gestión de usuarios</label>
                  <label class="campo-checkbox"><input type="checkbox" disabled> Gestión académica</label>
                  <label class="campo-checkbox"><input type="checkbox" disabled> Reportes administrativos</label>
                  <label class="campo-checkbox"><input type="checkbox" disabled> Bitácora de auditoría</label>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
