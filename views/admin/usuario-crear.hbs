<div class="app-wrapper">
  {{> sidebar-admin}}

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Crear Usuario</div>
        <div class="navbar-breadcrumb"><span>Inicio</span><span class="separador"></span><a href="/admin/usuarios">Usuarios</a><span class="separador"></span><span class="actual">Nuevo usuario</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="navbar-usuario"><div class="avatar">AM</div><div><div class="navbar-usuario-nombre">Ana Mora</div><div class="navbar-usuario-rol">Administradora TI</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Nuevo usuario</h1><p>Complete todos los campos requeridos para registrar un usuario en el sistema.</p></div>
        <div class="acciones-encabezado">
          <a href="/admin/usuarios" class="btn btn-secundario">Cancelar</a>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 300px;gap:1.5rem;" class="gap-col">
        <div>
          <!-- Datos personales -->
          <div class="carta mb-4">
            <div class="carta-cabecera"><div class="carta-titulo">Datos personales</div></div>
            <form id="form-crear-usuario">
            <div class="carta-cuerpo">
              <div class="campo-fila">
                <div class="campo">
                  <label>Nombre <span class="requerido">*</span></label>
                  <input id="crear-nombre" class="campo-input" type="text" placeholder="Ej: María" required>
                </div>
                <div class="campo">
                  <label>Apellido <span class="requerido">*</span></label>
                  <input id="crear-apellidos" class="campo-input" type="text" placeholder="Ej: Rodríguez Mora" required>
                </div>
              </div>
              <div class="campo">
                <label>Correo institucional <span class="requerido">*</span></label>
                <input id="crear-correo" class="campo-input" type="email" placeholder="usuario@universidad.ac.cr" required>
                <span class="campo-ayuda">Debe ser un correo institucional válido. Se usará para notificaciones.</span>
              </div>
              <div class="campo">
                <label>Identificador SSO <span class="requerido">*</span></label>
                <input id="crear-sso" class="campo-input" type="text" placeholder="Ej: mrodriguez-2024" required>
                <span class="campo-ayuda">Identificador único para autenticación. No se puede cambiar después.</span>
              </div>
              <div class="campo-fila">
                <div class="campo">
                  <label>Contraseña <span class="requerido">*</span></label>
                  <input id="crear-contrasena" class="campo-input" type="password" placeholder="Ingrese una contraseña" required>
                </div>
                <div class="campo">
                  <label>Confirmar contraseña <span class="requerido">*</span></label>
                  <input id="crear-contrasena2" class="campo-input" type="password" placeholder="Repetir contraseña" required>
                </div>
              </div>
            </div>

          <!-- Rol y acceso -->
          <div class="carta mb-4" style="margin-top:1.25rem;">
            <div class="carta-cabecera"><div class="carta-titulo">Rol y acceso</div></div>
            <div class="carta-cuerpo">
              <div class="campo">
                <label>Rol <span class="requerido">*</span></label>
                <select id="crear-rol" class="campo-input" required>
                  <option value="">Selecciona un rol...</option>
                </select>
              </div>
              <div class="alerta alerta-info">
                <span class="alerta-icono">ℹ️</span>
                <div>Si el rol es <strong>Estudiante</strong>, debes completar los datos académicos para crear también su registro en la tabla de estudiantes.</div>
              </div>
              <div id="bloque-estudiante" style="display:none;">
                <div class="campo">
                  <label>Programa académico <span class="requerido">*</span></label>
                  <select id="crear-programa" class="campo-input">
                    <option value="">Selecciona un programa...</option>
                  </select>
                </div>
                <div class="campo">
                  <label>Carné (opcional)</label>
                  <input id="crear-carne" class="campo-input" type="text" placeholder="Se genera automaticamente si se deja vacio">
                </div>
              </div>
              <div class="campo">
                <label class="campo-checkbox">
                  <input id="crear-activo" type="checkbox" checked> Cuenta activa al crear
                </label>
              </div>
            </div>
          </div>
          </form>
        </div>

        <!-- Panel lateral -->
        <div>
          <div class="carta mb-4">
            <div class="carta-cabecera"><div class="carta-titulo">Resumen</div></div>
            <div class="carta-cuerpo">
              <div style="text-align:center;padding:1rem 0;">
                <div id="preview-avatar" class="avatar avatar-lg" style="margin:0 auto 1rem;">?</div>
                <div id="preview-nombre" style="font-size:.875rem;color:var(--gris-suave);">El nombre aparecerá aquí</div>
              </div>
              <hr class="divisor">
              <div style="font-size:.875rem;display:flex;flex-direction:column;gap:.625rem;">
                <div class="flex-entre"><span class="texto-gris">Rol:</span><span id="preview-rol" class="semibold">—</span></div>
                <div class="flex-entre"><span class="texto-gris">Estado:</span><span class="badge badge-activo">Activo</span></div>
                <div class="flex-entre"><span class="texto-gris">Fecha:</span><span class="semibold">Hoy</span></div>
              </div>
            </div>
          </div>
          <div class="carta">
            <div class="carta-cuerpo">
              <button id="btn-crear-submit" class="btn btn-primario w-full mb-2">Crear usuario</button>
              <a href="/admin/usuarios" class="btn btn-secundario w-full" style="display:flex;align-items:center;justify-content:center;">Cancelar</a>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/admin-usuario-crear.js"></script>
