            <a href="/audit" style="display:flex;flex-direction:column;align-items:center;gap:.75rem;padding:1.25rem;background:var(--gris-fondo);border-radius:var(--radio-borde);text-decoration:none;transition:background var(--trans-base);" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background='var(--gris-fondo)'">
