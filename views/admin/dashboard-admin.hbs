<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script>
  // Alias extra para elementos duplicados en la misma página
  document.addEventListener('DOMContentLoaded', () => {
    const s2 = document.getElementById('met-sec2');
    const p2 = document.getElementById('met-pagos2');
    // Se rellenan después de que admin-dashboard.js actualice met-secciones / met-pagos-pend
    const obs = new MutationObserver(() => {
      if (s2) s2.textContent = document.getElementById('met-secciones')?.textContent || '—';
      if (p2) p2.textContent = document.getElementById('met-pagos-pend')?.textContent || '—';
    });
    const src1 = document.getElementById('met-secciones');
    const src2 = document.getElementById('met-pagos-pend');
    if (src1) obs.observe(src1, { childList: true, subtree: true, characterData: true });
    if (src2) obs.observe(src2, { childList: true, subtree: true, characterData: true });
  });
</script>
<script src="/js/admin-dashboard.js"></script>