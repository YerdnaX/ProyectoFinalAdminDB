        <div class="carta-cabecera"><div class="carta-titulo">Accesos rápidos</div></div>
        <div class="carta-cuerpo">
          <div class="grid-4">
            <a href="/admin/usuarios" style="display:flex;flex-direction:column;align-items:center;gap:.75rem;padding:1.25rem;background:var(--gris-fondo);border-radius:var(--radio-borde);text-decoration:none;transition:background var(--trans-base);" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background='var(--gris-fondo)'">
              <span style="font-size:2rem;">👥</span>
              <span style="font-size:.875rem;font-weight:600;color:var(--gris-oscuro);">Gestionar usuarios</span>
            </a>
            <a href="/academic/periodos" style="display:flex;flex-direction:column;align-items:center;gap:.75rem;padding:1.25rem;background:var(--gris-fondo);border-radius:var(--radio-borde);text-decoration:none;transition:background var(--trans-base);" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background='var(--gris-fondo)'">
              <span style="font-size:2rem;">📅</span>
              <span style="font-size:.875rem;font-weight:600;color:var(--gris-oscuro);">Periodos académicos</span>
            </a>
            <a href="/reports" style="display:flex;flex-direction:column;align-items:center;gap:.75rem;padding:1.25rem;background:var(--gris-fondo);border-radius:var(--radio-borde);text-decoration:none;transition:background var(--trans-base);" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background='var(--gris-fondo)'">
              <span style="font-size:2rem;">📈</span>
