        <div class="carta-metrica">
          <div class="metrica-icono">💰</div>
          <div class="metrica-etiqueta">Recaudación período</div>
          <div class="metrica-valor" id="met-recaudacion">—</div>
        </div>
        <div class="carta-metrica rojo">
          <div class="metrica-icono">🚫</div>
          <div class="metrica-etiqueta">Estudiantes bloqueados</div>
          <div class="metrica-valor" id="met-bloqueados">—</div>
          <div class="metrica-cambio negativo" id="met-block-fin"></div>
        </div>
      </div>

      <!-- Filas de contenido -->
      <div class="grid-2 mb-4" style="gap:1.5rem;">
        <!-- Actividad reciente -->
        <div class="carta">
          <div class="carta-cabecera">
            <div><div class="carta-titulo">Actividad reciente</div><div class="carta-subtitulo">Últimas acciones del sistema</div></div>
            <a href="/audit" class="btn btn-secundario btn-sm">Ver todo</a>
          </div>
          <div class="carta-cuerpo" style="padding:0;" id="actividad-reciente">
            <div style="padding:2rem;text-align:center;color:var(--gris-suave);">Cargando…</div>
          </div>
        </div>

        <!-- Estado de matrícula -->
        <div class="carta">
          <div class="carta-cabecera">
            <div><div class="carta-titulo">Estado de matrícula</div><div class="carta-subtitulo">Período activo</div></div>
            <a href="/enrollment/lista" class="btn btn-secundario btn-sm">Ver matrículas</a>
          </div>
          <div class="carta-cuerpo">
            <div style="margin-bottom:1.25rem;">
              <div style="display:flex;justify-content:space-between;font-size:.875rem;margin-bottom:.5rem;">
                <span>Confirmadas</span><span id="mat-conf-label" style="font-weight:700;color:var(--verde-principal);">—</span>
              </div>
              <div class="progreso-contenedor"><div class="progreso-barra" id="mat-conf-bar" style="width:0%;"></div></div>
            </div>
            <div style="margin-bottom:1.25rem;">
              <div style="display:flex;justify-content:space-between;font-size:.875rem;margin-bottom:.5rem;">
                <span>En proceso</span><span id="mat-pend-label" style="font-weight:700;color:var(--amarillo-alerta);">—</span>
              </div>
              <div class="progreso-contenedor"><div class="progreso-barra amarillo" id="mat-pend-bar" style="width:0%;"></div></div>
            </div>
            <hr class="divisor">
            <div class="grid-2">
              <div style="text-align:center;padding:1rem;background:var(--gris-fondo);border-radius:var(--radio-borde);">
