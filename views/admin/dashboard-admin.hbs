<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard Administrativo — Sistema de Matrícula</title>
<link rel="stylesheet" href="../../css/styles.css">
</head>
<body>
<div class="app-wrapper">

  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="sidebar-logo-icono">🎓</div>
      <div><div class="sidebar-logo-texto">UniMatrícula</div><div class="sidebar-logo-subtexto">Panel Administrativo</div></div>
    </div>
    <nav class="sidebar-nav">
      <div class="sidebar-seccion">General</div>
      <a href="dashboard-admin.html" class="activo"><span class="icono">📊</span> Dashboard</a>
      <div class="sidebar-seccion">Usuarios</div>
      <a href="usuarios-lista.html"><span class="icono">👥</span> Usuarios</a>
      <a href="roles-permisos.html"><span class="icono">🔐</span> Roles y permisos</a>
      <div class="sidebar-seccion">Académico</div>
      <a href="../academic/programas-lista.html"><span class="icono">🏛️</span> Programas académicos</a>
      <a href="../academic/planes-lista.html"><span class="icono">📋</span> Planes de estudio</a>
      <a href="../academic/cursos-lista.html"><span class="icono">📚</span> Cursos</a>
      <a href="../academic/periodos-lista.html"><span class="icono">📅</span> Periodos académicos</a>
      <div class="sidebar-seccion">Oferta</div>
      <a href="../academic/secciones-lista.html"><span class="icono">🗂️</span> Secciones</a>
      <a href="../academic/aulas-lista.html"><span class="icono">🏫</span> Aulas</a>
      <div class="sidebar-seccion">Estudiantes</div>
      <a href="../students/estudiantes-lista.html"><span class="icono">🎓</span> Estudiantes</a>
      <a href="../enrollment/matriculas-lista.html"><span class="icono">✏️</span> Matrículas</a>
      <div class="sidebar-seccion">Finanzas</div>
      <a href="../billing/facturas-lista.html"><span class="icono">🧾</span> Facturas</a>
      <a href="../billing/pagos-lista.html"><span class="icono">💳</span> Pagos</a>
      <div class="sidebar-seccion">Sistema</div>
      <a href="../notifications/notificaciones-lista.html"><span class="icono">🔔</span> Notificaciones</a>
      <a href="../reports/reportes.html"><span class="icono">📈</span> Reportes</a>
      <a href="../audit/bitacora.html"><span class="icono">🔍</span> Bitácora</a>
    </nav>
    <div class="sidebar-footer"><a href="../auth/login.html">🚪 Cerrar sesión</a></div>
  </aside>

  <!-- Contenido -->
  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Dashboard Administrativo</div>
        <div class="navbar-breadcrumb"><span>Inicio</span><span class="separador"></span><span class="actual">Dashboard</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="icono-notif">🔔<span class="badge-notif">4</span></div>
        <div class="navbar-usuario">
          <div class="avatar">AM</div>
          <div><div class="navbar-usuario-nombre">Ana Mora</div><div class="navbar-usuario-rol">Administradora TI</div></div>
        </div>
      </div>
    </header>

    <main class="area-pagina">
      <!-- Alerta período activo -->
      <div class="alerta alerta-verde mb-4">
        <span class="alerta-icono">📅</span>
        <div><span class="alerta-titulo">Período académico activo:</span> I Semestre 2025 — Matrícula abierta hasta el 28 de enero de 2025.</div>
      </div>

      <!-- Métricas -->
      <div class="grid-metricas">
        <div class="carta-metrica">
          <div class="metrica-icono">🎓</div>
          <div class="metrica-etiqueta">Estudiantes activos</div>
          <div class="metrica-valor">3,842</div>
          <div class="metrica-cambio positivo">▲ 5.2% vs período anterior</div>
        </div>
        <div class="carta-metrica">
          <div class="metrica-icono">✏️</div>
          <div class="metrica-etiqueta">Matrículas confirmadas</div>
          <div class="metrica-valor">2,619</div>
          <div class="metrica-cambio positivo">▲ 68.2% del total</div>
        </div>
        <div class="carta-metrica azul">
          <div class="metrica-icono">📚</div>
          <div class="metrica-etiqueta">Secciones ofertadas</div>
          <div class="metrica-valor">187</div>
          <div class="metrica-cambio positivo">▲ 12 nuevas</div>
        </div>
        <div class="carta-metrica amarillo">
          <div class="metrica-icono">💳</div>
          <div class="metrica-etiqueta">Pagos pendientes</div>
          <div class="metrica-valor">843</div>
          <div class="metrica-cambio negativo">▼ Requiere atención</div>
        </div>
        <div class="carta-metrica">
          <div class="metrica-icono">💰</div>
          <div class="metrica-etiqueta">Recaudación período</div>
          <div class="metrica-valor">₡482M</div>
          <div class="metrica-cambio positivo">▲ 8.1% vs meta</div>
        </div>
        <div class="carta-metrica rojo">
          <div class="metrica-icono">🚫</div>
          <div class="metrica-etiqueta">Estudiantes bloqueados</div>
          <div class="metrica-valor">124</div>
          <div class="metrica-cambio negativo">▼ 89 financiero / 35 académico</div>
        </div>
      </div>

      <!-- Filas de contenido -->
      <div class="grid-2 mb-4" style="gap:1.5rem;">
        <!-- Actividad reciente -->
        <div class="carta">
          <div class="carta-cabecera">
            <div><div class="carta-titulo">Actividad reciente</div><div class="carta-subtitulo">Últimas 24 horas</div></div>
            <a href="../audit/bitacora.html" class="btn btn-secundario btn-sm">Ver todo</a>
          </div>
          <div class="carta-cuerpo" style="padding:0;">
            <div style="padding:1rem 1.5rem;display:flex;gap:1rem;align-items:flex-start;border-bottom:1px solid var(--gris-linea);">
              <div style="width:36px;height:36px;border-radius:50%;background:var(--verde-bg-alt);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;">✏️</div>
              <div>
                <div style="font-size:.875rem;font-weight:600;">Matrícula confirmada</div>
                <div class="texto-pequeno">Laura Jiménez (2024-0312) — 4 cursos, 16 créditos</div>
                <div class="texto-pequeno" style="margin-top:.25rem;color:var(--gris-suave);">hace 12 minutos</div>
              </div>
            </div>
            <div style="padding:1rem 1.5rem;display:flex;gap:1rem;align-items:flex-start;border-bottom:1px solid var(--gris-linea);">
              <div style="width:36px;height:36px;border-radius:50%;background:var(--azul-info-bg);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;">👤</div>
              <div>
                <div style="font-size:.875rem;font-weight:600;">Nuevo usuario creado</div>
                <div class="texto-pequeno">Dr. Carlos Ugalde — Docente / Ingeniería en Sistemas</div>
                <div class="texto-pequeno" style="margin-top:.25rem;color:var(--gris-suave);">hace 45 minutos</div>
              </div>
            </div>
            <div style="padding:1rem 1.5rem;display:flex;gap:1rem;align-items:flex-start;border-bottom:1px solid var(--gris-linea);">
              <div style="width:36px;height:36px;border-radius:50%;background:var(--amarillo-alerta-bg);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;">💳</div>
              <div>
                <div style="font-size:.875rem;font-weight:600;">Pago registrado</div>
                <div class="texto-pequeno">Factura F-2025-08812 — ₡185,000</div>
                <div class="texto-pequeno" style="margin-top:.25rem;color:var(--gris-suave);">hace 1 hora</div>
              </div>
            </div>
            <div style="padding:1rem 1.5rem;display:flex;gap:1rem;align-items:flex-start;">
              <div style="width:36px;height:36px;border-radius:50%;background:var(--rojo-peligro-bg);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;">🚫</div>
              <div>
                <div style="font-size:.875rem;font-weight:600;">Bloqueo financiero activado</div>
                <div class="texto-pequeno">Roberto Solano (2023-1145) — Saldo pendiente ₡420,000</div>
                <div class="texto-pequeno" style="margin-top:.25rem;color:var(--gris-suave);">hace 2 horas</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Estado de matrícula -->
        <div class="carta">
          <div class="carta-cabecera">
            <div><div class="carta-titulo">Estado de matrícula</div><div class="carta-subtitulo">I Semestre 2025</div></div>
            <a href="../enrollment/matriculas-lista.html" class="btn btn-secundario btn-sm">Ver matrículas</a>
          </div>
          <div class="carta-cuerpo">
            <div style="margin-bottom:1.25rem;">
              <div style="display:flex;justify-content:space-between;font-size:.875rem;margin-bottom:.5rem;">
                <span>Confirmadas</span><span style="font-weight:700;color:var(--verde-principal);">2,619 (68.2%)</span>
              </div>
              <div class="progreso-contenedor"><div class="progreso-barra" style="width:68%;"></div></div>
            </div>
            <div style="margin-bottom:1.25rem;">
              <div style="display:flex;justify-content:space-between;font-size:.875rem;margin-bottom:.5rem;">
                <span>En proceso</span><span style="font-weight:700;color:var(--amarillo-alerta);">842 (21.9%)</span>
              </div>
              <div class="progreso-contenedor"><div class="progreso-barra amarillo" style="width:22%;"></div></div>
            </div>
            <div style="margin-bottom:1.25rem;">
              <div style="display:flex;justify-content:space-between;font-size:.875rem;margin-bottom:.5rem;">
                <span>Sin matrícula</span><span style="font-weight:700;color:var(--rojo-peligro);">381 (9.9%)</span>
              </div>
              <div class="progreso-contenedor"><div class="progreso-barra rojo" style="width:10%;"></div></div>
            </div>
            <hr class="divisor">
            <div class="grid-2">
              <div style="text-align:center;padding:1rem;background:var(--gris-fondo);border-radius:var(--radio-borde);">
                <div style="font-size:1.5rem;font-weight:700;color:var(--gris-oscuro);">187</div>
                <div class="texto-pequeno">Secciones activas</div>
              </div>
              <div style="text-align:center;padding:1rem;background:var(--verde-bg);border-radius:var(--radio-borde);">
                <div style="font-size:1.5rem;font-weight:700;color:var(--verde-principal);">94.2%</div>
                <div class="texto-pequeno">Ocupación promedio</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Accesos rápidos -->
      <div class="carta">
        <div class="carta-cabecera"><div class="carta-titulo">Accesos rápidos</div></div>
        <div class="carta-cuerpo">
          <div class="grid-4">
            <a href="usuarios-lista.html" style="display:flex;flex-direction:column;align-items:center;gap:.75rem;padding:1.25rem;background:var(--gris-fondo);border-radius:var(--radio-borde);text-decoration:none;transition:background var(--trans-base);" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background='var(--gris-fondo)'">
              <span style="font-size:2rem;">👥</span>
              <span style="font-size:.875rem;font-weight:600;color:var(--gris-oscuro);">Gestionar usuarios</span>
            </a>
            <a href="../academic/periodos-lista.html" style="display:flex;flex-direction:column;align-items:center;gap:.75rem;padding:1.25rem;background:var(--gris-fondo);border-radius:var(--radio-borde);text-decoration:none;transition:background var(--trans-base);" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background='var(--gris-fondo)'">
              <span style="font-size:2rem;">📅</span>
              <span style="font-size:.875rem;font-weight:600;color:var(--gris-oscuro);">Periodos académicos</span>
            </a>
            <a href="../reports/reportes.html" style="display:flex;flex-direction:column;align-items:center;gap:.75rem;padding:1.25rem;background:var(--gris-fondo);border-radius:var(--radio-borde);text-decoration:none;transition:background var(--trans-base);" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background='var(--gris-fondo)'">
              <span style="font-size:2rem;">📈</span>
              <span style="font-size:.875rem;font-weight:600;color:var(--gris-oscuro);">Generar reportes</span>
            </a>
            <a href="../audit/bitacora.html" style="display:flex;flex-direction:column;align-items:center;gap:.75rem;padding:1.25rem;background:var(--gris-fondo);border-radius:var(--radio-borde);text-decoration:none;transition:background var(--trans-base);" onmouseover="this.style.background='var(--verde-bg)'" onmouseout="this.style.background='var(--gris-fondo)'">
              <span style="font-size:2rem;">🔍</span>
              <span style="font-size:.875rem;font-weight:600;color:var(--gris-oscuro);">Bitácora auditoría</span>
            </a>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
</body>
</html>
