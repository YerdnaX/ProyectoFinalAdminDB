<div class="app-wrapper">
  {{> sidebar-admin}}

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Catálogo de Cursos</div>
        <div class="navbar-breadcrumb"><span>Inicio</span><span class="separador"></span><span class="actual">Cursos</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="navbar-usuario"><div class="avatar">AM</div><div><div class="navbar-usuario-nombre">Ana Mora</div><div class="navbar-usuario-rol">Administradora TI</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Catálogo de cursos</h1><p>Administra el catálogo completo de cursos del sistema.</p></div>
        <div class="acciones-encabezado">
          <button class="btn btn-secundario">Exportar</button>
          <button id="btn-nuevo-curso" class="btn btn-primario">+ Nuevo curso</button>
        </div>
      </div>

      <div class="carta">
        <div class="carta-cabecera">
          <div class="barra-filtros" style="margin:0;flex:1;">
            <div class="barra-busqueda"><span class="icono-buscar">🔍</span><input id="input-buscar" type="text" placeholder="Buscar por nombre o código..."></div>
            <select id="sel-creditos" class="filtro-select"><option value="">Todos los créditos</option><option value="1">1</option><option value="2">2</option><option value="3">3</option><option value="4">4</option></select>
          </div>
        </div>

        <div class="tabla-contenedor">
          <table class="tabla">
            <thead>
              <tr>
                <th>Código</th>
                <th>Nombre</th>
                <th>Créditos</th>
                <th>Horas/sem.</th>
                <th>Prerrequisitos</th>
                <th>Estado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody id="tbody-cursos">
              <tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--gris-suave);">Cargando…</td></tr>
            </tbody>
          </table>
        </div>
        <div id="paginacion-cursos" class="paginacion"></div>
      </div>
    </main>
  </div>
</div>
<!-- Modal crear curso -->
<div id="modal-crear-curso" class="modal">
  <div class="modal-overlay" onclick="U.closeModal('modal-crear-curso')"></div>
  <div class="modal-caja" style="max-width:520px;">
    <div class="modal-cabecera">
      <div class="modal-titulo">Nuevo curso</div>
      <button class="modal-cerrar" onclick="U.closeModal('modal-crear-curso')">✕</button>
    </div>
    <form id="form-crear-curso" class="modal-cuerpo" style="display:flex;flex-direction:column;gap:1rem;">
      <div class="campo" style="margin:0;">
        <label>Código <span class="requerido">*</span></label>
        <input name="codigo" class="campo-input" required placeholder="ej. IS-1101">
      </div>
      <div class="campo" style="margin:0;">
        <label>Nombre <span class="requerido">*</span></label>
        <input name="nombre" class="campo-input" required placeholder="Nombre del curso">
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="campo" style="margin:0;">
          <label>Créditos <span class="requerido">*</span></label>
          <input name="creditos" class="campo-input" type="number" min="1" max="10" required placeholder="ej. 4">
        </div>
        <div class="campo" style="margin:0;">
          <label>Horas semanales</label>
          <input name="horas_semanales" class="campo-input" type="number" min="1" placeholder="ej. 4">
        </div>
      </div>
      <div class="campo" style="margin:0;">
        <label>Descripción</label>
        <textarea name="descripcion" class="campo-input" rows="3" placeholder="Descripción opcional del curso"></textarea>
      </div>
      <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem;">
        <button type="button" class="btn btn-secundario" onclick="U.closeModal('modal-crear-curso')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Guardar</button>
      </div>
    </form>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/academic-cursos.js"></script>