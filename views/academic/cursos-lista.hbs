                <td><div class="nombre-principal">Estructuras de Datos</div><div class="detalle-secundario">Listas, árboles, grafos y algoritmos de ordenamiento</div></td>
                <td><span style="font-weight:700;">4</span></td>
                <td>4</td>
                <td><div style="display:flex;gap:.375rem;flex-wrap:wrap;"><span class="badge badge-info">IS-1101</span></div></td>
                <td><span class="badge badge-activo">Activo</span></td>
                <td><div class="acciones-fila"><button class="btn btn-secundario btn-sm">Ver</button><button class="btn btn-secundario btn-sm">Editar</button></div></td>
