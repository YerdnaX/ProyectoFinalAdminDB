                  </div>
                </td>
                <td><span class="badge badge-info">Presencial</span></td>
                <td><span class="badge badge-activo">Abierta</span></td>
                <td><div class="acciones-fila"><button class="btn btn-secundario btn-sm">Ver</button><button class="btn btn-secundario btn-sm">Editar</button></div></td>
              </tr>
              <tr>
                <td><span style="font-family:monospace;font-weight:700;color:var(--verde-principal);">IS-1101-02</span></td>
                <td><div class="nombre-principal">Fundamentos de Programación</div><div class="detalle-secundario">IS-1101 · 4 créditos</div></td>
                <td><div class="nombre-principal">M.Sc. Patricia Vega</div></td>
                <td class="texto-muted">Lab B-101</td>
                <td class="texto-muted">Ma-Ju 9:00–11:00</td>
                <td>
                  <div style="min-width:100px;">
                    <div style="display:flex;justify-content:space-between;font-size:.75rem;margin-bottom:.25rem;"><span>40 / 40</span><span style="color:var(--rojo-peligro);">100%</span></div>
                    <div class="progreso-contenedor"><div class="progreso-barra rojo" style="width:100%;"></div></div>
                  </div>
                </td>
                <td><span class="badge badge-info">Presencial</span></td>
                <td><span class="badge badge-error">Llena</span></td>
                <td><div class="acciones-fila"><button class="btn btn-secundario btn-sm">Ver</button><button class="btn btn-secundario btn-sm">Editar</button></div></td>
              </tr>
              <tr>
                <td><span style="font-family:monospace;font-weight:700;color:var(--verde-principal);">IS-2202-01</span></td>
                <td><div class="nombre-principal">Base de Datos I</div><div class="detalle-secundario">IS-2202 · 3 créditos</div></td>
                <td><div class="nombre-principal">Ing. Manuel Salas</div></td>
