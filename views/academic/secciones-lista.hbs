                <td><div class="acciones-fila"><button class="btn btn-secundario btn-sm">Ver</button><button class="btn btn-primario btn-sm">Asignar</button></div></td>
              </tr>
            </tbody>
          </table>
        </div>
        <div id="paginacion-secciones" class="paginacion"></div>
      </div>
    </main>
  </div>
</div>
<!-- Modal crear sección -->
<div id="modal-crear-seccion" class="modal">
  <div class="modal-overlay" onclick="U.closeModal('modal-crear-seccion')"></div>
  <div class="modal-caja" style="max-width:560px;">
    <div class="modal-cabecera">
      <div class="modal-titulo">Nueva sección</div>
      <button class="modal-cerrar" onclick="U.closeModal('modal-crear-seccion')">✕</button>
    </div>
    <form id="form-crear-seccion" class="modal-cuerpo" style="display:flex;flex-direction:column;gap:1rem;">
      <div class="campo" style="margin:0;">
        <label>Curso <span class="requerido">*</span></label>
        <select id="sec-curso" name="id_curso" class="campo-input" required>
          <option value="">Seleccionar curso…</option>
        </select>
      </div>
      <div class="campo" style="margin:0;">
        <label>Periodo <span class="requerido">*</span></label>
        <select id="sec-periodo" name="id_periodo" class="campo-input" required>
          <option value="">Seleccionar periodo…</option>
        </select>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="campo" style="margin:0;">
          <label>Código de sección <span class="requerido">*</span></label>
          <input name="codigo_seccion" class="campo-input" required placeholder="ej. 01">
        </div>
        <div class="campo" style="margin:0;">
          <label>Cupo máximo <span class="requerido">*</span></label>
          <input name="cupo_maximo" class="campo-input" type="number" min="1" required placeholder="ej. 30">
        </div>
      </div>
      <div class="campo" style="margin:0;">
        <label>Docente</label>
        <select id="sec-docente" name="id_docente_usuario" class="campo-input">
          <option value="">Sin asignar</option>
        </select>
      </div>
      <div class="campo" style="margin:0;">
        <label>Aula</label>
        <select id="sec-aula" name="id_aula" class="campo-input">
          <option value="">Sin asignar</option>
        </select>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="campo" style="margin:0;">
          <label>Modalidad</label>
          <select name="modalidad" class="campo-input">
            <option value="Presencial">Presencial</option>
            <option value="Virtual">Virtual</option>
            <option value="Híbrido">Híbrido</option>
          </select>
        </div>
        <div class="campo" style="margin:0;">
          <label>Estado</label>
          <select name="estado" class="campo-input">
            <option value="Abierta">Abierta</option>
            <option value="Cerrada">Cerrada</option>
          </select>
        </div>
      </div>
      <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem;">
        <button type="button" class="btn btn-secundario" onclick="U.closeModal('modal-crear-seccion')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Guardar</button>
      </div>
    </form>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/academic-secciones.js"></script>