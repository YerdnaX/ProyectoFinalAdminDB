                <td><span class="badge badge-activo">Abierta</span></td>
                <td><div class="acciones-fila"><button class="btn btn-secundario btn-sm">Ver</button><button class="btn btn-secundario btn-sm">Editar</button></div></td>
              </tr>
              <tr>
