                <td class="texto-muted">L-Mi-V 11:00–12:00</td>
                <td>
                  <div style="min-width:100px;">
                    <div style="display:flex;justify-content:space-between;font-size:.75rem;margin-bottom:.25rem;"><span>18 / 30</span><span style="color:var(--amarillo-alerta);">60%</span></div>
                    <div class="progreso-contenedor"><div class="progreso-barra amarillo" style="width:60%;"></div></div>
