<div class="app-wrapper">
  {{> sidebar-admin}}

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Secciones</div>
        <div class="navbar-breadcrumb"><span>Inicio</span><span class="separador"></span><span class="actual">Secciones</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="navbar-usuario"><div class="avatar">AM</div><div><div class="navbar-usuario-nombre">Ana Mora</div><div class="navbar-usuario-rol">Administradora TI</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Oferta de secciones</h1><p>Gestiona secciones, docentes, aulas y horarios.</p></div>
        <div class="acciones-encabezado">
          <button id="btn-nueva-seccion" class="btn btn-primario">+ Nueva seccion</button>
        </div>
      </div>

      <div class="carta">
        <div class="carta-cabecera">
          <div class="barra-filtros" style="margin:0;flex:1;">
            <div class="barra-busqueda"><span class="icono-buscar">&#128269;</span><input id="input-buscar-secciones" type="text" placeholder="Buscar por seccion, curso, docente o aula..."></div>
            <select id="filtro-periodo" class="filtro-select"><option value="">Todos los periodos</option></select>
            <select id="filtro-aula" class="filtro-select"><option value="">Todas las aulas</option></select>
            <select id="filtro-estado" class="filtro-select"><option value="">Todos los estados</option><option value="Abierta">Abierta</option><option value="Cerrada">Cerrada</option><option value="Cancelada">Cancelada</option></select>
          </div>
        </div>

        <div class="tabla-contenedor">
          <table class="tabla">
            <thead>
              <tr>
                <th>Sesion</th>
                <th>Curso</th>
                <th>Docente</th>
                <th>Aula asignada</th>
                <th>Horario</th>
                <th>Cupos maximos</th>
                <th>Estado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody id="tbody-secciones">
              <tr><td colspan="8" style="text-align:center;padding:2rem;color:var(--gris-suave);">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</div>

<div id="modal-crear-seccion" class="modal">
  <div class="modal-overlay" onclick="U.closeModal('modal-crear-seccion')"></div>
  <div class="modal-caja" style="max-width:560px;">
    <div class="modal-cabecera">
      <div class="modal-titulo">Nueva seccion</div>
      <button class="modal-cerrar" onclick="U.closeModal('modal-crear-seccion')">&times;</button>
    </div>
    <form id="form-crear-seccion" class="modal-cuerpo" style="display:flex;flex-direction:column;gap:1rem;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="campo" style="margin:0;">
          <label>Sesion <span class="requerido">*</span></label>
          <input name="codigo_seccion" class="campo-input" required placeholder="ej. 01">
        </div>
        <div class="campo" style="margin:0;">
          <label>Periodo <span class="requerido">*</span></label>
          <select id="sec-periodo" name="id_periodo" class="campo-input" required>
            <option value="">Seleccionar periodo...</option>
          </select>
        </div>
      </div>
      <div class="campo" style="margin:0;">
        <label>Curso <span class="requerido">*</span></label>
        <select id="sec-curso" name="id_curso" class="campo-input" required>
          <option value="">Seleccionar curso...</option>
        </select>
      </div>
      <div class="campo" style="margin:0;">
        <label>Docente <span class="requerido">*</span></label>
        <select id="sec-docente" name="id_docente_usuario" class="campo-input" required>
          <option value="">Seleccionar docente...</option>
        </select>
      </div>
      <div class="campo" style="margin:0;">
        <label>Aula asignada <span class="requerido">*</span></label>
        <select id="sec-aula" name="id_aula" class="campo-input" required>
          <option value="">Seleccionar aula...</option>
        </select>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;">
        <div class="campo" style="margin:0;">
          <label>Dia</label>
          <select name="dia_semana" class="campo-input">
            <option value="">Sin horario</option>
            <option value="Lunes">Lunes</option>
            <option value="Martes">Martes</option>
            <option value="Miercoles">Miercoles</option>
            <option value="Jueves">Jueves</option>
            <option value="Viernes">Viernes</option>
            <option value="Sabado">Sabado</option>
            <option value="Domingo">Domingo</option>
          </select>
        </div>
        <div class="campo" style="margin:0;">
          <label>Hora inicio</label>
          <input name="hora_inicio" class="campo-input" type="time">
        </div>
        <div class="campo" style="margin:0;">
          <label>Hora fin</label>
          <input name="hora_fin" class="campo-input" type="time">
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="campo" style="margin:0;">
          <label>Cantidad maxima de cupos <span class="requerido">*</span></label>
          <input id="sec-cupo" name="cupo_maximo" class="campo-input" type="number" min="1" required placeholder="Se ajusta por capacidad del aula">
          <small id="sec-capacidad-help" style="color:var(--gris-suave);">Seleccione un aula para validar la capacidad.</small>
        </div>
        <div class="campo" style="margin:0;">
          <label>Estado</label>
          <input class="campo-input" value="Si" readonly>
          <input type="hidden" name="estado" value="Abierta">
        </div>
      </div>
      <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem;">
        <button type="button" class="btn btn-secundario" onclick="U.closeModal('modal-crear-seccion')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Guardar</button>
      </div>
    </form>
  </div>
</div>

<div id="modal-editar-seccion" class="modal">
  <div class="modal-overlay" onclick="U.closeModal('modal-editar-seccion')"></div>
  <div class="modal-caja" style="max-width:560px;">
    <div class="modal-cabecera">
      <div class="modal-titulo">Editar seccion</div>
      <button class="modal-cerrar" onclick="U.closeModal('modal-editar-seccion')">&times;</button>
    </div>
    <form id="form-editar-seccion" class="modal-cuerpo" style="display:flex;flex-direction:column;gap:1rem;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="campo" style="margin:0;">
          <label>Sesion <span class="requerido">*</span></label>
          <input name="codigo_seccion" class="campo-input" required>
        </div>
        <div class="campo" style="margin:0;">
          <label>Periodo <span class="requerido">*</span></label>
          <select id="sec-periodo-ed" name="id_periodo" class="campo-input" required>
            <option value="">Seleccionar periodo...</option>
          </select>
        </div>
      </div>
      <div class="campo" style="margin:0;">
        <label>Curso <span class="requerido">*</span></label>
        <select id="sec-curso-ed" name="id_curso" class="campo-input" required>
          <option value="">Seleccionar curso...</option>
        </select>
      </div>
      <div class="campo" style="margin:0;">
        <label>Docente <span class="requerido">*</span></label>
        <select id="sec-docente-ed" name="id_docente_usuario" class="campo-input" required>
          <option value="">Seleccionar docente...</option>
        </select>
      </div>
      <div class="campo" style="margin:0;">
        <label>Aula asignada <span class="requerido">*</span></label>
        <select id="sec-aula-ed" name="id_aula" class="campo-input" required>
          <option value="">Seleccionar aula...</option>
        </select>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;">
        <div class="campo" style="margin:0;">
          <label>Dia</label>
          <select name="dia_semana" class="campo-input">
            <option value="">Sin horario</option>
            <option value="Lunes">Lunes</option>
            <option value="Martes">Martes</option>
            <option value="Miercoles">Miercoles</option>
            <option value="Jueves">Jueves</option>
            <option value="Viernes">Viernes</option>
            <option value="Sabado">Sabado</option>
            <option value="Domingo">Domingo</option>
          </select>
        </div>
        <div class="campo" style="margin:0;">
          <label>Hora inicio</label>
          <input name="hora_inicio" class="campo-input" type="time">
        </div>
        <div class="campo" style="margin:0;">
          <label>Hora fin</label>
          <input name="hora_fin" class="campo-input" type="time">
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="campo" style="margin:0;">
          <label>Cantidad maxima de cupos <span class="requerido">*</span></label>
          <input id="sec-cupo-ed" name="cupo_maximo" class="campo-input" type="number" min="1" required>
          <small id="sec-capacidad-help-ed" style="color:var(--gris-suave);">Seleccione un aula para validar la capacidad.</small>
        </div>
        <div class="campo" style="margin:0;">
          <label>Estado</label>
          <input class="campo-input" value="Si" readonly>
          <input type="hidden" name="estado" value="Abierta">
        </div>
      </div>
      <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem;">
        <button type="button" class="btn btn-secundario" onclick="U.closeModal('modal-editar-seccion')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Actualizar</button>
      </div>
    </form>
  </div>
</div>

<style>
  #modal-crear-seccion,
  #modal-editar-seccion {
    position: fixed;
    inset: 0;
    width: 100vw;
    max-width: none;
    max-height: none;
    border-radius: 0;
    box-shadow: none;
    overflow: visible;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    z-index: 1200;
    background: rgba(15, 23, 42, .55);
  }
  #modal-crear-seccion.abierto,
  #modal-editar-seccion.abierto { display: flex; }

  #modal-crear-seccion .modal-overlay,
  #modal-editar-seccion .modal-overlay { position: absolute; inset: 0; }

  #modal-crear-seccion .modal-caja,
  #modal-editar-seccion .modal-caja {
    position: relative;
    z-index: 1;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    background: var(--fondo-carta);
    border-radius: var(--radio-grande);
    box-shadow: var(--sombra-modal);
  }

  #modal-crear-seccion .modal-cerrar,
  #modal-editar-seccion .modal-cerrar {
    background: none;
    border: none;
    color: var(--gris-suave);
    font-size: 1.25rem;
    cursor: pointer;
    line-height: 1;
  }
  #modal-crear-seccion .modal-cerrar:hover,
  #modal-editar-seccion .modal-cerrar:hover { color: var(--gris-oscuro); }
</style>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/academic-secciones.js"></script>
