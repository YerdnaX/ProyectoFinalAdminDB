<div class="app-wrapper">
  {{> sidebar-admin}}

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Periodos Academicos</div>
        <div class="navbar-breadcrumb"><span>Inicio</span><span class="separador"></span><span class="actual">Periodos academicos</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="navbar-usuario"><div class="avatar">AM</div><div><div class="navbar-usuario-nombre">Ana Mora</div><div class="navbar-usuario-rol">Administradora TI</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Periodos academicos</h1><p>Gestiona semestres, cuatrimestres, matricula y limites de creditos.</p></div>
        <div class="acciones-encabezado"><button id="btn-nuevo-periodo" class="btn btn-primario">+ Nuevo periodo</button></div>
      </div>

      <div class="barra-filtros">
        <div class="barra-busqueda"><span class="icono-buscar">Buscar</span><input id="fil-buscar-periodo" type="text" placeholder="Buscar por codigo o nombre..."></div>
        <select id="sel-tipo-periodo" class="filtro-select">
          <option value="">Todos los tipos</option>
          <option value="Semestre">Semestre</option>
          <option value="Cuatrimestre">Cuatrimestre</option>
          <option value="Trimestre">Trimestre</option>
        </select>
        <select id="sel-estado-periodo" class="filtro-select">
          <option value="">Todos los estados</option>
          <option value="1">Activo</option>
          <option value="0">Inactivo</option>
        </select>
        <button id="btn-buscar-periodo" class="btn btn-primario btn-sm">Buscar</button>
      </div>

      <div class="carta">
        <div class="carta-cabecera"><div class="carta-titulo">Historial de periodos</div></div>
        <div class="tabla-contenedor">
          <table class="tabla">
            <thead>
              <tr>
                <th>Codigo</th>
                <th>Nombre</th>
                <th>Tipo</th>
                <th>Periodo lectivo</th>
                <th>Ventana matricula</th>
                <th>Lim. creditos</th>
                <th>Estado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody id="tbody-periodos">
              <tr><td colspan="8" style="text-align:center;padding:2rem;color:var(--gris-suave);">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</div>

<!-- Modal crear/editar periodo -->
<div id="modal-periodo" class="modal">
  <div class="modal-overlay" onclick="U.closeModal('modal-periodo')"></div>
  <div class="modal-caja" style="max-width:620px;">
    <div class="modal-cabecera">
      <div class="modal-titulo" id="modal-periodo-titulo">Nuevo periodo academico</div>
      <button type="button" class="modal-cerrar" onclick="U.closeModal('modal-periodo')">x</button>
    </div>
    <form id="form-periodo" class="modal-cuerpo" style="display:flex;flex-direction:column;gap:1rem;">
      <input type="hidden" id="periodo-id">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="campo" style="margin:0;">
          <label>Codigo <span class="requerido">*</span></label>
          <input id="periodo-codigo" name="codigo" class="campo-input" maxlength="20" required placeholder="ej. 2026-1">
        </div>
        <div class="campo" style="margin:0;">
          <label>Tipo <span class="requerido">*</span></label>
          <select id="periodo-tipo" name="tipo_periodo" class="campo-input" required>
            <option value="">Seleccionar...</option>
            <option value="Semestre">Semestre</option>
            <option value="Cuatrimestre">Cuatrimestre</option>
            <option value="Trimestre">Trimestre</option>
          </select>
        </div>
      </div>
      <div class="campo" style="margin:0;">
        <label>Nombre <span class="requerido">*</span></label>
        <input id="periodo-nombre" name="nombre" class="campo-input" maxlength="100" required placeholder="ej. Primer Cuatrimestre 2026">
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="campo" style="margin:0;">
          <label>Inicio lectivo <span class="requerido">*</span></label>
          <input id="periodo-inicio" name="fecha_inicio" class="campo-input" type="date" required>
        </div>
        <div class="campo" style="margin:0;">
          <label>Fin lectivo <span class="requerido">*</span></label>
          <input id="periodo-fin" name="fecha_fin" class="campo-input" type="date" required>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="campo" style="margin:0;">
          <label>Inicio matricula <span class="requerido">*</span></label>
          <input id="periodo-inicio-mat" name="fecha_inicio_matricula" class="campo-input" type="date" required>
        </div>
        <div class="campo" style="margin:0;">
          <label>Fin matricula <span class="requerido">*</span></label>
          <input id="periodo-fin-mat" name="fecha_fin_matricula" class="campo-input" type="date" required>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="campo" style="margin:0;">
          <label>Limite de creditos <span class="requerido">*</span></label>
          <input id="periodo-creditos" name="limite_creditos" class="campo-input" type="number" min="1" max="30" required placeholder="ej. 16">
        </div>
        <div class="campo" style="margin:0;">
          <label>Estado</label>
          <select id="periodo-activo" name="activo" class="campo-input">
            <option value="1">Activo</option>
            <option value="0">Inactivo</option>
          </select>
        </div>
      </div>
      <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem;">
        <button type="button" class="btn btn-secundario" onclick="U.closeModal('modal-periodo')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Guardar</button>
      </div>
    </form>
  </div>
</div>

<style>
  #modal-periodo {
    position: fixed;
    inset: 0;
    width: 100vw;
    max-width: none;
    max-height: none;
    border-radius: 0;
    box-shadow: none;
    overflow: visible;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    z-index: 1200;
    background: rgba(15, 23, 42, .55);
  }
  #modal-periodo.abierto { display: flex; }
  #modal-periodo .modal-overlay { position: absolute; inset: 0; }
  #modal-periodo .modal-caja {
    position: relative;
    z-index: 1;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    background: var(--fondo-carta);
    border-radius: var(--radio-grande);
    box-shadow: var(--sombra-modal);
  }
  #modal-periodo .modal-cerrar {
    background: none;
    border: none;
    color: var(--gris-suave);
    font-size: 1.25rem;
    cursor: pointer;
    line-height: 1;
  }
  #modal-periodo .modal-cerrar:hover { color: var(--gris-oscuro); }
</style>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/academic-periodos.js"></script>
