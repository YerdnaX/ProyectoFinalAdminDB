<div class="app-wrapper">
  {{> sidebar-admin}}

  <div class="contenido-principal">
    <header class="navbar">
      <div>
        <div class="navbar-titulo">Periodos Académicos</div>
        <div class="navbar-breadcrumb"><span>Inicio</span><span class="separador"></span><span class="actual">Periodos académicos</span></div>
      </div>
      <div class="navbar-acciones">
        <div class="navbar-usuario"><div class="avatar">AM</div><div><div class="navbar-usuario-nombre">Ana Mora</div><div class="navbar-usuario-rol">Administradora TI</div></div></div>
      </div>
    </header>

    <main class="area-pagina">
      <div class="encabezado-pagina">
        <div><h1>Periodos académicos</h1><p>Gestiona los semestres, cuatrimestres y la apertura de matrícula.</p></div>
        <div class="acciones-encabezado"><button id="btn-nuevo-periodo" class="btn btn-primario">+ Nuevo periodo</button></div>
      </div>

      <!-- Periodo activo destacado -->
      <div style="background:var(--verde-principal);border-radius:var(--radio-grande);padding:1.5rem 2rem;margin-bottom:1.5rem;color:#fff;">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
          <div>
            <div style="font-size:.875rem;opacity:.8;margin-bottom:.25rem;">⚡ Periodo activo</div>
            <div style="font-size:1.375rem;font-weight:700;margin-bottom:.25rem;">I Semestre 2025</div>
            <div style="font-size:.875rem;opacity:.85;">Código: 2025-I • Tipo: Semestral</div>
          </div>
          <div style="display:flex;gap:2rem;text-align:center;">
            <div><div style="font-size:1.5rem;font-weight:700;">18 feb – 30 jun</div><div style="font-size:.8125rem;opacity:.8;">Período lectivo</div></div>
            <div style="width:1px;background:rgba(255,255,255,.3);"></div>
            <div><div style="font-size:1.5rem;font-weight:700;">15 – 28 ene</div><div style="font-size:.8125rem;opacity:.8;">Ventana de matrícula</div></div>
            <div style="width:1px;background:rgba(255,255,255,.3);"></div>
            <div><div style="font-size:1.5rem;font-weight:700;">20</div><div style="font-size:.8125rem;opacity:.8;">Límite de créditos</div></div>
          </div>
          <div style="display:flex;gap:.75rem;">
            <button class="btn" style="background:rgba(255,255,255,.2);color:#fff;border:1px solid rgba(255,255,255,.4);">Cerrar matrícula</button>
            <button class="btn" style="background:#fff;color:var(--verde-principal);">Editar periodo</button>
          </div>
        </div>
      </div>

      <div class="carta">
        <div class="carta-cabecera"><div class="carta-titulo">Historial de periodos</div></div>
        <div class="tabla-contenedor">
          <table class="tabla">
            <thead>
              <tr>
                <th>Código</th>
                <th>Nombre</th>
                <th>Tipo</th>
                <th>Periodo lectivo</th>
                <th>Ventana matrícula</th>
                <th>Lím. créditos</th>
                <th>Estado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody id="tbody-periodos">
              <tr><td colspan="8" style="text-align:center;padding:2rem;color:var(--gris-suave);">Cargando…</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</div>
<!-- Modal crear periodo -->
<div id="modal-crear-periodo" class="modal">
  <div class="modal-overlay" onclick="U.closeModal('modal-crear-periodo')"></div>
  <div class="modal-caja" style="max-width:560px;">
    <div class="modal-cabecera">
      <div class="modal-titulo">Nuevo periodo académico</div>
      <button class="modal-cerrar" onclick="U.closeModal('modal-crear-periodo')">✕</button>
    </div>
    <form id="form-crear-periodo" class="modal-cuerpo" style="display:flex;flex-direction:column;gap:1rem;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="campo" style="margin:0;">
          <label>Código <span class="requerido">*</span></label>
          <input name="codigo" class="campo-input" required placeholder="ej. 2025-I">
        </div>
        <div class="campo" style="margin:0;">
          <label>Tipo <span class="requerido">*</span></label>
          <select name="tipo_periodo" class="campo-input" required>
            <option value="">Seleccionar…</option>
            <option value="Semestral">Semestral</option>
            <option value="Cuatrimestral">Cuatrimestral</option>
            <option value="Trimestral">Trimestral</option>
          </select>
        </div>
      </div>
      <div class="campo" style="margin:0;">
        <label>Nombre <span class="requerido">*</span></label>
        <input name="nombre" class="campo-input" required placeholder="ej. I Semestre 2025">
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="campo" style="margin:0;">
          <label>Inicio lectivo <span class="requerido">*</span></label>
          <input name="fecha_inicio" class="campo-input" type="date" required>
        </div>
        <div class="campo" style="margin:0;">
          <label>Fin lectivo <span class="requerido">*</span></label>
          <input name="fecha_fin" class="campo-input" type="date" required>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div class="campo" style="margin:0;">
          <label>Inicio matrícula</label>
          <input name="fecha_inicio_matricula" class="campo-input" type="date">
        </div>
        <div class="campo" style="margin:0;">
          <label>Fin matrícula</label>
          <input name="fecha_fin_matricula" class="campo-input" type="date">
        </div>
      </div>
      <div class="campo" style="margin:0;">
        <label>Límite de créditos</label>
        <input name="limite_creditos" class="campo-input" type="number" min="1" max="30" placeholder="ej. 20">
      </div>
      <div style="display:flex;gap:.75rem;justify-content:flex-end;margin-top:.5rem;">
        <button type="button" class="btn btn-secundario" onclick="U.closeModal('modal-crear-periodo')">Cancelar</button>
        <button type="submit" class="btn btn-primario">Guardar</button>
      </div>
    </form>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/utils.js"></script>
<script src="/js/academic-periodos.js"></script>